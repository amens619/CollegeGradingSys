@using CollegeGradingSys.Utilities.Extensions
@inject SignInManager<IdentityUser> signInManger

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] - نظام إدارة الدرجات</title>

    <!-- أيقونة الموقع -->
    <link rel="icon" href="~/images/favicon.ico" type="image/x-icon">

    <!-- أقسام CSS المخصصة -->
    @await RenderSectionAsync("AcademicYearCss", required: false)

    <!-- خطوط جوجل (Source Sans Pro) -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="~/admin/plugins/fontawesome-free/css/all.min.css">
    <!-- Ionicons -->
    <link rel="stylesheet" href="https://code.ionicframework.com/ionicons/2.0.1/css/ionicons.min.css">

    <!-- مكتبات وثيم AdminLTE RTL -->
    <link rel="stylesheet" href="~/admin/plugins/tempusdominus-bootstrap-4/css/tempusdominus-bootstrap-4.min.css">
    <link rel="stylesheet" href="~/admin/plugins/icheck-bootstrap/icheck-bootstrap.min.css">
    <link rel="stylesheet" href="~/admin/plugins/jqvmap/jqvmap.min.css">
    <link rel="stylesheet" href="~/admin/dist/css/adminlte_rtl.css">
    <link rel="stylesheet" href="~/admin/plugins/overlayScrollbars/css/OverlayScrollbars.min.css">
    <link rel="stylesheet" href="~/admin/plugins/daterangepicker/daterangepicker.css">
    <link rel="stylesheet" href="~/admin/plugins/summernote/summernote-bs4.min.css">

    <!-- Bootstrap 4 RTL -->
    <link rel="stylesheet" href="https://cdn.rtlcss.com/bootstrap/v4.2.1/css/bootstrap.min.css">

    <!-- ملفات النظام المخصصة -->
    <link rel="stylesheet" href="~/admin/dist/css/custom.css">
    <link rel="stylesheet" href="~/css/vanillaSelectBox.css" />

    <style>
        .card-header {
            background-color: transparent;
        }

        .custom-file-input ~ .custom-file-label::after {
            content: "استعراض";
        }

        /* تنسيقات الـ Pagination العصرية */
        .custom-pagination {
            border-radius: 50px;
            overflow: hidden;
            background-color: #fff;
        }

            .custom-pagination .page-item .page-link {
                color: #28a745;
                border: none;
                padding: 10px 18px;
                font-weight: 500;
                transition: all 0.3s ease;
            }

            .custom-pagination .page-item:not(.active):not(.disabled) .page-link:hover {
                background-color: #e8f5e9;
                color: #1e7e34;
                transform: translateY(-2px);
            }

            .custom-pagination .page-item.active .page-link {
                background-color: #28a745;
                color: white;
                border-radius: 50px;
                box-shadow: 0 4px 8px rgba(40, 167, 69, 0.3);
                z-index: 1;
            }

            .custom-pagination .page-item.disabled .page-link {
                color: #6c757d;
                background-color: #f8f9fa;
            }
    </style>
</head>
<body class="hold-transition sidebar-mini layout-navbar-fixed">
    <div class="wrapper">

        <!-- Preloader -->
        <div class="preloader flex-column justify-content-center align-items-center">
            <img class="animation__shake" src="~/images/favicon.ico" alt="نظام إدارة الدرجات" height="60" width="60">
        </div>

        <!-- Navbar -->
        <nav class="main-header navbar navbar-expand navbar-white navbar-light">
            <!-- Left navbar links -->
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
                </li>
                <li class="nav-item d-none d-sm-inline-block">
                    <a href="#" class="nav-link">حول</a>
                </li>
            </ul>

            <!-- Right navbar links -->
            <ul class="navbar-nav ml-auto">
                <li class="nav-item">
                    <a class="nav-link" data-widget="fullscreen" href="#" role="button">
                        <i class="fas fa-expand-arrows-alt"></i>
                    </a>
                </li>
            </ul>
        </nav>
        <!-- /.navbar -->
        <!-- Main Sidebar Container -->
        <aside class="main-sidebar sidebar-dark-secondary elevation-4">
            <!-- Brand Logo -->
            <a class="brand-link" style="background-color: #3C7C72" asp-controller="Home" asp-action="Index">
                <img src="~/images/favicon.ico" alt="نظام القبول والتسجيل الجامعي" class="brand-image img-circle elevation-3" style="opacity: .8">
                <span class="brand-text font-weight-light ">القبول والتسجيل الجامعي</span>
            </a>

            <!-- Sidebar -->
            <div class="sidebar">
                <!-- Sidebar user panel -->
                <div class="user-panel mt-3 pb-3 mb-3 d-flex">
                    <partial name="_LoginPartial" />
                </div>

                <!-- Sidebar Menu -->
                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">

                        <!-- قسم إعدادات النظام -->
                        <li class="nav-item @Html.IfAnyPageActive(new string[] { "Adminstration", "DBSettings" })">
                            <a href="#" class="nav-link @Html.IfAnyPageActive2(new string[] { "Adminstration", "DBSettings" })">
                                <i class="nav-icon fas fa-cog"></i>
                                <p>قسم إعدادات النظام <i class="left fas fa-angle-left"></i></p>
                            </a>
                            <ul class="nav nav-treeview">
                                <li class="nav-item">
                                    <a href="~/GeneralInfo" style="font-size:small" class="nav-link @Html.IfPageActive("Adminstration")">
                                        <i class="far fa-circle nav-icon"></i><p>الاعدادات العامة</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="~/Adminstration/ListUsers" style="font-size:small" class="nav-link @Html.IfPageActive("Adminstration")">
                                        <i class="far fa-circle nav-icon"></i><p>حسابات المستخدمين</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="~/DBSettings" style="font-size:small" class="nav-link @Html.IfPageActive("DBSettings")">
                                        <i class="far fa-circle nav-icon"></i><p>الخزن</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- قسم الإعدادات الأكاديمية -->
                        <li class="nav-item @Html.IfAnyPageActive(new string[] { "College", "Department", "Specialization", "Nationality", "Governorate", "AcademicYear", "Batch", "Course" })">
                            <a href="#" class="nav-link @Html.IfAnyPageActive2(new string[] { "College", "Department", "Specialization", "Nationality", "Governorate", "AcademicYear", "Batch", "Course" })">
                                <i class="nav-icon fas fa-th"></i>
                                <p>قسم الإعدادات الأكاديمية <i class="left fas fa-angle-left"></i></p>
                            </a>
                            <ul class="nav nav-treeview">
                                <li class="nav-item">
                                    <a href="~/College" style="font-size:small" class="nav-link @Html.IfPageActive("College")">
                                        <i class="far fa-circle nav-icon"></i><p>إدارة الكليات</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="~/Department" style="font-size:small" class="nav-link @Html.IfPageActive("Department")">
                                        <i class="far fa-circle nav-icon"></i><p>إدارة الاقسام</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="~/Specialization" style="font-size:small" class="nav-link @Html.IfPageActive("Specialization")">
                                        <i class="far fa-circle nav-icon"></i><p>إدارة التخصصات</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="~/Nationality" style="font-size:small" class="nav-link @Html.IfPageActive("Nationality")">
                                        <i class="far fa-circle nav-icon"></i><p>إدارة الدول والجنسيات</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="~/Governorate" style="font-size:small" class="nav-link @Html.IfPageActive("Governorate")">
                                        <i class="far fa-circle nav-icon"></i><p>إدارة المحافظات</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="~/AcademicYear" style="font-size:small" class="nav-link @Html.IfPageActive("AcademicYear")">
                                        <i class="far fa-circle nav-icon"></i><p>إدارة العام الجامعي</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="~/Batch" style="font-size:small" class="nav-link @Html.IfPageActive("Batch")">
                                        <i class="far fa-circle nav-icon"></i><p>إدارة الدفعات</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="~/Course" style="font-size:small" class="nav-link @Html.IfPageActive("Course")">
                                        <i class="far fa-circle nav-icon"></i><p>إدارة المواد</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- قسم شؤون الطلاب -->
                        <li class="nav-item @Html.IfAnyPageActive(new string[] { "StPersonalData", "StAcademicData" })">
                            <a href="#" class="nav-link @Html.IfAnyPageActive2(new string[] { "StPersonalData", "StAcademicData" })">
                                <i class="nav-icon fas fa-user-graduate"></i>
                                <p>قسم شؤون الطلاب <i class="left fas fa-angle-left"></i></p>
                            </a>
                            <ul class="nav nav-treeview">
                                <li class="nav-item">
                                    <a asp-controller="StPersonalData" asp-action="Index" style="font-weight:100" asp-route-IsSelectCurrentYear="True" class="nav-link @Html.IfPageActive("StPersonalData")">
                                        <i class="far fa-circle nav-icon"></i><p>البيانات الشخصية</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a asp-controller="StAcademicData" asp-action="Index" style="font-weight:100" asp-route-IsSelectCurrentYear="True" class="nav-link @Html.IfPageActive("StAcademicData")">
                                        <i class="far fa-circle nav-icon"></i><p>البيانات الأكاديمية</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- قسم الكنترول ورصد الدرجات -->
                        <li class="nav-item @Html.IfAnyPageActive(new string[] { "CourseGrade" })">
                            <a href="#" class="nav-link @Html.IfAnyPageActive2(new string[] { "AllbatchCourseGrade", "AllbatchCourseGradeFailed" })">
                                <i class="nav-icon fas fa-edit"></i>
                                <p>قسم الكنترول ورصد الدرجات <i class="left fas fa-angle-left"></i></p>
                            </a>
                            <ul class="nav nav-treeview">
                                <li class="nav-item">
                                    <a asp-controller="CourseGrade" asp-action="AllbatchCourseGrade" style="font-weight:100" class="nav-link @Html.IfPageActive("CourseGrade", "AllbatchCourseGrade")">
                                        <i class="far fa-circle nav-icon"></i><p>درجات المادة للدفعة</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a asp-controller="CourseGrade" asp-action="AllbatchCourseGradeFailed" style="font-weight:100" asp-route-IsSelectCurrentYear="True" class="nav-link @Html.IfPageActive("CourseGrade", "AllbatchCourseGradeFailed")">
                                        <i class="far fa-circle nav-icon"></i><p>درجات المادة التكميلية</p>
                                    </a>
                                </li>                               
                                
                            </ul>
                        </li>

                    </ul>
                </nav>
                <!-- /.sidebar-menu -->
            </div>
            <!-- /.sidebar -->
        </aside>

        <!-- Content Wrapper -->
        <div class="content-wrapper">
            <!-- Content Header -->
            <div class="content-header">
                <div class="container-fluid">
                    <div class="row mb-2">
                        <div class="col-sm-6">
                            <h4 class="m-0 text-dark font-weight-bold">@ViewData["PageName"]</h4>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-right">
                                <li class="breadcrumb-item text-muted">@ViewData["SubPageName"]</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            @RenderBody()

        </div>
        <!-- /.content-wrapper -->

        <footer class="main-footer text-sm">
            <strong>جميع الحقوق محفوظة &copy; @DateTime.Now.Year <a class="text-success" href="#">نظام إدارة الدرجات</a>.</strong>
            <div class="float-right d-none d-sm-inline-block">
                <b>الإصدار</b> 3.0
            </div>
        </footer>

    </div>
    <!-- ./wrapper -->
    <!-- ==============================================
                     Scripts (البرمجيات)
    =============================================== -->
    <!-- Core JS -->
    <script src="~/admin/plugins/jquery/jquery.min.js"></script>
    <script src="~/admin/plugins/jquery-ui/jquery-ui.min.js"></script>
    <script>
        $.widget.bridge('uibutton', $.ui.button)
    </script>
    <script src="~/admin/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>

    <!-- Plugins -->
    <script src="~/admin/plugins/chart.js/Chart.min.js"></script>
    <script src="~/admin/plugins/sparklines/sparkline.js"></script>
    <script src="~/admin/plugins/jqvmap/jquery.vmap.min.js"></script>
    <script src="~/admin/plugins/jqvmap/maps/jquery.vmap.usa.js"></script>
    <script src="~/admin/plugins/jquery-knob/jquery.knob.min.js"></script>
    <script src="~/admin/plugins/moment/moment.min.js"></script>
    <script src="~/admin/plugins/daterangepicker/daterangepicker.js"></script>
    <script src="~/admin/plugins/tempusdominus-bootstrap-4/js/tempusdominus-bootstrap-4.min.js"></script>
    <script src="~/admin/plugins/summernote/summernote-bs4.min.js"></script>
    <script src="~/admin/plugins/overlayScrollbars/js/jquery.overlayScrollbars.min.js"></script>

    <!-- AdminLTE App -->
    <script src="~/admin/dist/js/adminlte.js"></script>

    <!-- Validation & Custom Scripts -->
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/vanillaSelectBox.js"></script>

    <!-- Custom Event Handlers -->
    <script>
        $(document).ready(function () {
            // إصلاح كود الـ JavaScript الخاص بالقائمة الجانبية
            $(".mainmenu").click(function () {
                var isExpanded = $(this).attr('aria-expanded') === "true";
                if (isExpanded) {
                    $('.mainmenu').attr("aria-expanded", "true");
                } else {
                    $('.mainmenu').attr("aria-expanded", "false");
                }
            });
        });
    </script>

    <!-- Sections (تم دمج الأقسام المتعددة لتفادي أخطاء النظام مستقبلاً) -->
    @await RenderSectionAsync("AcademicYearScripts", required: false)
    @await RenderSectionAsync("FileTypeScripts", required: false)
    @await RenderSectionAsync("OtherSourceScripts", required: false)
    @await RenderSectionAsync("StudyAndSurveyScripts", required: false)
    @await RenderSectionAsync("ContractScripts", required: false)
    @await RenderSectionAsync("AdministrativeDocsTemplatesScripts", required: false)
    @await RenderSectionAsync("GuidPoliciesScripts", required: false)
    @await RenderSectionAsync("ProjectScripts", required: false)

    <!-- السكريبت الرئيسي الخاص بكل شاشة -->
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>