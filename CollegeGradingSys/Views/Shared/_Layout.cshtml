<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="">
    <meta name="author" content="Mark Otto, Jacob Thornton, and Bootstrap contributors">
    <meta name="generator" content="Hugo 0.84.0">
    <title>@ViewData["Title"] - نظام إدارة الدرجات</title>
    <link href="~/css/sidebars.css" rel="stylesheet" />


    <link href="~/lib/twitter-bootstrap/css/bootstrap.css" rel="stylesheet" />

    @*<script src="https://unpkg.com/feather-icons"></script>*@
    <link rel="stylesheet" href="~/css/site.css" />
    <!-- Custom styles for this template -->
    <link href="~/css/dashboard.rtl.css" rel="stylesheet" />
    <style>
        .bd-placeholder-img {
            font-size: 1.125rem;
            text-anchor: middle;
            -webkit-user-select: none;
            -moz-user-select: none;
            user-select: none;
        }

        /* media (min-width: 768px) {
          .bd-placeholder-img-lg {
            font-size: 3.5rem;
          }
        }*/
    </style>



    @*<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    *@
</head>
<body>
    <heade>

        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark sticky-top bg-dark flex-md-nowrap p-0 shadow border-bottom      box-shadow ">
            <a class="navbar-brand navbarbrand col-md-3 bg-dark col-lg-2 text-warning me-0 px-3" asp-area="" asp-controller="Home" asp-action="Index">نظام إدارة الدرجات</a>
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            @*<div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">

                    <partial name="_LoginPartial" />
                </div>*@

        </nav>

    </heade>
    <div>
        <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block bg-white sidebar collapse">
            <div class="position-sticky pt-3">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link  text-success active" asp-area="" asp-controller="Home" asp-action="Index">
                            <span class="text-success" data-feather="home"></span>
                            الصفحة الرئيسية
                        </a>
                    </li>
                    <li class="nav-item">
                        <button class="btn btn-toggle align-items-center  collapsed mainmenu" data-bs-toggle="collapse" data-bs-target="#dashboard-collapse" aria-expanded="true">
                            <span data-feather="settings"></span>
                            الاعدادات العامة
                        </button>
                        <div class="collapse" id="dashboard-collapse">
                            <ul class="btn-toggle-nav list-unstyled fw-normal pb-1 small">
                                <li><a href="~/College" class="link-dark rounded">إدارة الكليات</a></li>
                                <li><a href="~/Department" class="link-dark rounded">إدارة الاقسام</a></li>
                                <li><a href="~/Specialization" class="link-dark rounded">إدارة التخصصات</a></li>
                                <li><a href="~/Nationality" class="link-dark rounded">إدارة الدول والجنسيات</a></li>
                                <li><a href="~/Governorate" class="link-dark rounded">إدارة المحافظات</a></li>
                                @*<li><a href="~/District" class="link-dark rounded">إدارة المديريات</a></li>
                                <li><a href="~/City" class="link-dark rounded">إدارة المدن</a></li>*@
                                <li><a href="~/AcademicYear" class="link-dark rounded">إدارة العام الجامعي</a></li>
                                <li><a href="~/Batch" class="link-dark rounded">إدارة الدفعات</a></li>
                                <li><a href="~/Course" class="link-dark rounded">إدارة المواد </a></li>
                            </ul>
                        </div>
                    </li>
                    <li class="nav-item">
                        <button class="btn btn-toggle align-items-center rounded collapsed mainmenu" data-bs-toggle="collapse" data-bs-target="#St-collapse" aria-expanded="true">
                            <span data-feather="users"></span>
                            ادارة الطلاب
                        </button>
                        <div class="collapse" id="St-collapse">
                            <ul class="btn-toggle-nav list-unstyled fw-normal pb-1 small">
                                <li><a asp-controller="/StPersonalData" asp-action="Index" class="link-dark rounded" asp-route-IsSelectCurrentYear="True">البيانات الشخصية</a></li>
                                <li><a asp-controller="/StAcademicData" asp-action="Index" class="link-dark rounded" asp-route-IsSelectCurrentYear="True">البيانات الأكاديمية</a></li>
                            </ul>
                        </div>
                    </li>
                    <li class="nav-item">
                        <button class="btn btn-toggle align-items-center rounded collapsed mainmenu" data-bs-toggle="collapse" data-bs-target="#Grading-collapse" aria-expanded="true">
                            <span data-feather="edit"></span>
                            ادارةالدرجات
                        </button>
                        <div class="collapse" id="Grading-collapse">
                            <ul class="btn-toggle-nav list-unstyled fw-normal pb-1 small">
                                @*<li><a href="~/CourseGrade" class="link-dark rounded">درجات الطالب</a></li>*@
                                <li><a href="~/CourseGrade/AllbatchCourseGrade" class="link-dark rounded">درجات لمادة دراسية للدفعة</a></li>
                                <li><a asp-controller="/CourseGrade"  asp-action="AllbatchCourseGradeFailed" class="link-dark rounded" asp-route-IsSelectCurrentYear="True">درجات الطلاب لمادة دراسية تكميلية</a></li>
                            </ul>
                        </div>

                    </li>
                    @*<li class="nav-item">
                        <a class="nav-link mainmenu" href="#">
                            <span data-feather="bar-chart-2"></span>
                            التقارير
                        </a>
                    </li>*@
                </ul>

            </div>

        </nav>
        <main role="main" class=" me-sm-auto   p-3 bg-light mainDiv  ">
            <div class="container-fluid   p-0 justify-content-md-end">
                @RenderBody()
            </div>
            <div class="position-fixed bottom-0 start-0 p-3" style="z-index: 11">
                <div id="liveToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="toast-header">
                        @*<img src="..." class="rounded me-2" alt="...">*@
                        <strong class="me-auto">Bootstrap</strong>
                        <small>11 mins ago</small>
                        <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                    <div class="toast-body">
                        Hello, world! This is a toast message.
                    </div>
                </div>
            </div>

        </main>
        
        <footer class="border-top footer col-md-9 text-muted ">           
            <div class="container">
                &copy; 2022 - نظام إدارة الدرجات  @*<a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>*@
            </div>
        </footer>
    </div>

    @*<script src="~/lib/jquery/dist/jquery.min.js"></script>*@
    <script src="~/lib/jquery/jquery.js"></script>
    <script src="~/lib/popper.js/umd/popper.js"></script>
    @*<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>*@
    <script src="~/lib/twitter-bootstrap/js/bootstrap.js"></script>

    @*<script src="~/js/dashboard.js"></script>*@
    <script src="~/js/sidebars.js"></script>
    <script src="~/lib/feather-icons/feather.js"></script>
    <script>
        feather.replace()
    </script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function () {
            $(".mainmenu").click(function () {

                //var gggg = $(this).attr('aria-expanded');
                //alert(gggg);
                //var sss = $(this).find('[aria-expanded]').attr('aria-expanded');
                //alert(sss);
                if ($(this).attr('aria-expanded') == "true") {
                    //alert("display");
                    document.getElementsByClassName('mainmenu').setAttribute("aria-expanded", "true");
                    $(this).setAttribute("aria-expanded", "true");
                } else {
                    //alert("display none");
                    document.getElementsByClassName('mainmenu').setAttribute("aria-expanded", "false");
                    //$(this).setAttribute("aria-expanded", "true");
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
