@using CollegeGradingSys.Models.Enums
@model CollegeGradingSys.ViewModels.EditCourseGradeViewModel
<!-- Modal -->
<div class="modal fade " id="add-contact" tabindex="-1" role="dialog" aria-labelledby="addContactLabel" aria-hidden="true">
    <form asp-action="Edit">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <h5 class="modal-title" id="addContactLabel">تعديل المادة </h5>
                </div>

                
                <div class="modal-body row">

                    <input name="IsValid" type="hidden" value="@ViewData.ModelState.IsValid.ToString()" />
                    <input asp-for="IsSubCourse" type="hidden" />
                    <input asp-for="ParentId" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="form-group col-md-6">
                        <label asp-for="CourseName" class="control-label"></label>
                        <input asp-for="CourseName" readonly class="form-control text-center" />
                        <span asp-validation-for="CourseName" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-6">
                        <label asp-for="CourseType" class="control-label"></label>
                        <input asp-for="CourseType" readonly class="form-control text-center" />
                        <span asp-validation-for="CourseType" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-3">
                        <label id="BigGrade" asp-for="BigGrade" class="control-label"></label>
                        <input asp-for="BigGrade" type="number" readonly class="form-control text-center" />
                        <span asp-validation-for="BigGrade" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-3">
                        <label asp-for="SmallGrade" class="control-label"></label>
                        <input id="SmallGrade"  type="number" asp-for="SmallGrade" readonly class="form-control text-center" />
                        <span asp-validation-for="SmallGrade" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-6">
                        <label asp-for="StStatusForCourse" class="control-label"></label>
                        <select id="EditStStatusForCourse" asp-for="StStatusForCourse" class="form-control text-center"
                                asp-items="Html.GetEnumSelectList<StStatusForCourse>()"></select>
                        <span asp-validation-for="StStatusForCourse" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-6">
                        <label asp-for="Grade" class="control-label"></label>
                        @*@Html.TextBox("Grade", 0.00D, null)*@
                        <input id="EditCourseGrade" 
                               onkeypress="CheckNumeric()"  asp-for="Grade" class="form-control text-center" />
                        <span asp-validation-for="Grade" class="text-danger"></span>
                    </div>


                </div>
                <div class="modal-footer justify-content-between">
                    <button type="button" data-save="modal" class="btn btn-success">حفظ</button>
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">إلغاء الأمر</button>

                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}