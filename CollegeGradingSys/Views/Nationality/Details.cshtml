@model CollegeGradingSys.ViewModels.Nationality.NationalityVM

@{
    ViewData["Title"] = "التفصيل";
}

<div class="card mb-4">
    <div class="card-body">
        <div class="bg-white">
            <h5 class="mb-4">  <span style="margin-left:6px;" data-feather="edit"></span>إدارة الدول والجنسيات</h5>
            <h6 class="m-1">التفصيل</h6>
            <hr class="mb-4 mt-0">
            <div class="row">
                <div class="col-md-12">
                    <div class="row my-5">
                        <div class="col-sm-2">
                            @Html.DisplayNameFor(model => model.CountryName)
                        </div>
                        <div class="col-sm-10">
                            @Html.DisplayFor(model => model.CountryName)
                        </div>
                        <div class="col-sm-2">
                            @Html.DisplayNameFor(model => model.NationalityName)
                        </div>
                        <div class="col-sm-10">
                            @Html.DisplayFor(model => model.NationalityName)
                        </div>                        
                    </div>
                <div>
                    <a asp-action="Edit" class="btn btn-primary btn-sm align-self-center" asp-route-id="@Model.Id">تعديل</a>
                    <a class="btn btn-secondary  btn-sm" asp-action="Index">القائمة الرئسية</a>
                </div>
            </div>
        </div>
    </div>
</div>

