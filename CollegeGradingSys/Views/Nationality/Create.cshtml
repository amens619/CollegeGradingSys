@model CollegeGradingSys.Models.Nationality
@{
    ViewData["Title"] = "إضافة دولة جديدة";
    }
<div class="card mb-4">
    <div class="card-body">
        <div class="bg-white">
            <h5 class="mb-4">  <span style="margin-left:6px;" data-feather="plus"></span>إدارة الدول والجنسيات</h5>
            <h6 class="m-1">إضافة دولة جديدة</h6>
            <hr class="mb-4 mt-0">
            <div class="row col-md-12">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="row">
                        <div class="form-group col-md-6">
                            <label asp-for="CountryName" class="control-label"></label>
                            <input asp-for="CountryName" class="form-control" />
                            <span asp-validation-for="CountryName" class="text-danger"></span>
                        </div>

                        <div class="form-group col-md-6">
                            <label asp-for="NationalityName" class="control-label"></label>
                            <input asp-for="NationalityName" class="form-control" />
                            <span asp-validation-for="NationalityName" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="form-group mt-4">
                        <input type="submit" value="إضافة" class="btn col-2 btn-primary btn-sm" />
                        <a class="btn btn-secondary  btn-sm" asp-action="Index">القائمة الرئسية</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
