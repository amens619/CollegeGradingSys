@model CollegeGradingSys.ViewModels.Nationality.NationalityVM

@{
    ViewData["Title"] = "التعديل";
    ViewData["PageName"] = "إدارة الدول والجنسيات";
    //ViewData["SubPageName"] = "القائمة الرئسية";
}

<!-- Main content -->
<section class="content">
    <div class="container-fluid">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="row">
                <div class="col-md-8 px-0 offset-md-2">
                    <div class="card">
                        <div class="card-header ui-sortable-handle" style="cursor: move;">
                            <h3 class="card-title">
                                التعديل
                            </h3>
                        </div>
                        <!-- /.card-header -->
                        <div class="card-body">
                            <div class="row">
                                <div class="form-group col-md-6">
                                    <label asp-for="CountryName" class="control-label"></label>
                                    <input asp-for="CountryName" class="form-control" />
                                    <span asp-validation-for="CountryName" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-6">
                                    <label asp-for="NationalityName" class="control-label"></label>
                                    <input asp-for="NationalityName" class="form-control" />
                                    <span asp-validation-for="NationalityName" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer">

                            <input type="submit" value="حفظ" class="col-2 btn btn-success btn-sm" />
                            <a class="btn btn-secondary  btn-sm" asp-action="Index">القائمة الرئسية</a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
