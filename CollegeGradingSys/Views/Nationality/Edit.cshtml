@model CollegeGradingSys.Models.Nationality

@{
    ViewData["Title"] = "التعديل";
}

<div class="card mb-4">
    <div class="card-body">
        <div class="bg-white">
            <h5 class="mb-4">  <span style="margin-left:6px;" data-feather="edit"></span>إدارة الدول والجنسيات</h5>
            <h6 class="m-1">التعديل</h6>
            <hr class="mb-4 mt-0">
            <div class="row">
                <div class="col-md-12">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Id" />
                        <div class="row">
                            <div class="form-group col-md-6">
                                <label asp-for="CountryName" class="control-label"></label>
                                <input asp-for="CountryName" class="form-control" />
                                <span asp-validation-for="CountryName" class="text-danger"></span>
                            </div>
                            <div class="form-group col-md-6">
                                <label asp-for="NationalityName" class="control-label"></label>
                                <input asp-for="NationalityName" class="form-control" />
                                <span asp-validation-for="NationalityName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="form-group mt-4">
                            <input type="submit" value="حفظ" class="col-2 btn btn-primary btn-sm" />
                            <a class="btn btn-secondary  btn-sm" asp-action="Index">القائمة الرئسية</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
