@model IEnumerable<CollegeGradingSys.Models.AcademicYear>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.AcademicYearStart)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AcademicYearEnd)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AcademicYearName)
            </th>           
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.AcademicYearStart)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.AcademicYearEnd)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.AcademicYearName)
            </td>
            
            <td>
                <a asp-action="Index" asp-controller="Batch" asp-route-id="@item.Id">الدفعات</a> |
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
