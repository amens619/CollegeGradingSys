@using CollegeGradingSys.ViewModels.AcademicYear
@model AcademicYearEditVM


@{
    ViewData["Title"] = "التعديل";
    ViewData["PageName"] = "إدارة العام الجامعي";
    //ViewData["SubPageName"] = "القائمة الرئسية";
}


<!-- Main content -->
<section class="content">
    <div class="container-fluid">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="IsCurrentYear" />
            <div class="row">
                <div class="col-md-8 px-0 offset-md-2">
                    <div class="card">
                        <div class="card-header ui-sortable-handle" style="cursor: move;">
                            <h3 class="card-title">
                                التعديل
                            </h3>
                        </div>
                        <!-- /.card-header -->
                        <div class="card-body">
                            <div class="row">
                                <div class="form-group col-md-3">
                                    <label asp-for="AcademicYearStart" class="control-label"></label>
                                    <input asp-for="AcademicYearStart" class="form-control" type="date" />                         
                                    @* <input asp-for="AcademicYearStart" class="form-control" data-val="true" data-val-date="الرجاء ادخال الصغية الصحيحة للتاريخ" data-val-required="الرجاء ادخال التاريخ" /> *@
                                    <span asp-validation-for="AcademicYearStart" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-3">
                                    <label asp-for="AcademicYearEnd" class="control-label"></label>
                                    <input asp-for="AcademicYearEnd" class="form-control" type="date" />
                                    @* <input asp-for="AcademicYearEnd" class="form-control" data-val="true" data-val-date="الرجاء ادخال الصغية الصحيحة للتاريخ" data-val-required="الرجاء ادخال التاريخ" /> *@
                                    <span asp-validation-for="AcademicYearEnd" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-3">
                                    <label asp-for="AcademicYearName" class="control-label"></label>
                                    <input asp-for="AcademicYearName" class="form-control" data-val="true" data-val-required="الرجاء ادخال العام الجامعي " />
                                    <span asp-validation-for="AcademicYearName" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-3">
                                    <label asp-for="AcademicYearNameH" class="control-label"></label>
                                    <input asp-for="AcademicYearNameH" class="form-control" data-val="true" data-val-required="الرجاء ادخال العام الجامعي " />
                                    <span asp-validation-for="AcademicYearNameH" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-12">
                                    <label asp-for="Note" class="control-label"></label>
                                    <textarea asp-for="Note" class="form-control" rows="3"></textarea>
                                    <span asp-validation-for="Note" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer">

                            <input type="submit" value="حفظ" class="col-2 btn btn-outline-success btn-sm" />
                            <a class="btn btn-secondary  btn-sm" asp-action="Index">القائمة الرئسية</a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
