@model CollegeGradingSys.Models.AcademicYear

@{
    ViewData["Title"] = "إضافة عام جامعي";
}

<div class="card mb-4">
    <div class="card-body">
        <div class="bg-white">
            <h5 class="mb-4">  <span style="margin-left:6px;" data-feather="plus"></span>إدارة العام الجامعي</h5>
            <h6 class="m-1">إضافة عام جامعي</h6>
            <hr class="mb-4 mt-0">
            <div class="row col-md-12">
                <form asp-action="Create">
                    @if (ViewBag.Message != null)
                    {
                        <h5 class="alert alert-danger">@ViewBag.Message</h5>
                    }
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="row">
                        <div class="form-group col-md-4">
                            <label asp-for="AcademicYearStart" class="control-label"></label>
                            <input asp-for="AcademicYearStart"  class="form-control text-center" data-val="true" data-val-date="يجب ادخال الصغية الصحيحة للتاريخ" data-val-required="الرجاء ادخال التاريخ" />
                            <span asp-validation-for="AcademicYearStart" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-4">
                            <label asp-for="AcademicYearEnd" class="control-label"></label>
                            <input asp-for="AcademicYearEnd" class="form-control text-center" data-val="true" data-val-date="يجب ادخال الصغية الصحيحة للتاريخ" data-val-required="الرجاء ادخال التاريخ" />
                            <span asp-validation-for="AcademicYearEnd" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-4">
                            <label asp-for="AcademicYearName" class="control-label"></label>
                            <input asp-for="AcademicYearName" class="form-control text-center" data-val="true"  data-val-required="الرجاء ادخال العام الجامعي " />
                            <span asp-validation-for="AcademicYearName" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-12">
                            <label asp-for="Note" class="control-label"></label>
                            <input asp-for="Note" class="form-control" />
                            <span asp-validation-for="Note" class="text-danger"></span>
                        </div>
                        @*<input type="text" data-val="true" data-val-length="Length must be between 10 to 25" data-val-length-max="25" data-val-length-min="10" data-val-required="Please enter the name" id="Name" name="Name" value="" />
                        <span class="field-validation-valid" data-valmsg-for="Name" data-valmsg-replace="true"></span>
                        <br />*@

                    </div>
                    <div class="form-group mt-4">
                        <input type="submit" value="إضافة" class="btn col-2 btn-primary btn-sm" />
                        <a class="btn btn-secondary  btn-sm" asp-action="Index">القائمة الرئسية</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
