@model CollegeGradingSys.Models.AcademicYear


@{
    ViewData["Title"] = "حذف عام جامعي";
    ViewData["PageName"] = "إدارة العام الجامعي";
    //ViewData["SubPageName"] = "القائمة الرئسية";
}
<!-- Main content -->
<section class="content">
    <div class="container-fluid ">
        <div class="row">
            <div class="card card-outline px-0 card-danger col-md-8 offset-md-2">
                <div class="card-body">
                    <div class="row mx-3 ">
                        <h4>هل تريد بالفعل حذف العام الجامعي ؟!!</h4>
                        <div class="col-12">
                            <hr />
                            @if (ViewBag.Message != null)
                            {
                                <h5 class="alert alert-danger">@ViewBag.Message</h5>
                            }
                            <div class="row my-4">
                                <div class="col-sm-3 my-2">
                                    @Html.DisplayNameFor(model => model.AcademicYearStart)
                                </div>
                                <div class="col-sm-9 my-2">
                                    @Html.DisplayFor(model => model.AcademicYearStart)
                                </div>
                                <div class="col-sm-3 my-2">
                                    @Html.DisplayNameFor(model => model.AcademicYearEnd)
                                </div>
                                <div class="col-sm-9 my-2">
                                    @Html.DisplayFor(model => model.AcademicYearEnd)
                                </div>
                                <div class="col-sm-3 my-2">
                                    @Html.DisplayNameFor(model => model.AcademicYearName)
                                </div>
                                <div class="col-sm-9 my-2">
                                    @Html.DisplayFor(model => model.AcademicYearName)
                                </div>
                                <div class="col-sm-3 my-2">
                                    @Html.DisplayNameFor(model => model.Note)
                                </div>
                                <div class="col-sm-9 my-2">
                                    @Html.DisplayFor(model => model.Note)
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="card-footer">
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <input type="submit" value="حذف" class="btn btn-danger btn-sm " />
                        <a class="btn btn-secondary  btn-sm" asp-action="Index">إلغاء الامر</a>
                    </form>
                </div>

            </div>
        </div>
    </div>
</section>
