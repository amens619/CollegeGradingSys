@model IEnumerable<IdentityRole>   

@{
    ViewData["Title"] = "كل الادوار و المسؤوليات";
    ViewData["PageName"] = "حسابات المستخدمين";
    ViewData["SubPageName"] = "القائمة الرئسية";
}


<div class="card mb-4">

    <div class="card-body">
        <div class="bg-white">                   
            <p>
                <a class="btn btn-secondary col-2 btn-sm" asp-action="CreateRole" asp-controller="Adminstration">دور جديد</a>
            </p>
            <div class="card mb-4">
                <div class="card-body">                   
                    <hr class="my-4">
                    @if(@Model.Any()){
 <table class="table table-bordered">
                         <thead class="table-light">
                             <tr>
                               
                                <th scope="col" class=" col text-center" style="vertical-align: middle;">
                                   الدور او المسؤولية
                                </th>
                                <th></th>
                            </tr>
                    </thead>
                    <tbody>
                @foreach (var Role in Model) {
                        <tr>
                           
                            <td class="text-center" >
                                @Html.DisplayFor(modelItem => Role.Name)
                            </td>
                            <td class="text-center" >                                
                                    <a asp-action="EditRole" asp-controller="Adminstration" class="btn btn-outline-primary btn-sm align-self-center" asp-route-id="@Role.Id">
                                         <i class="fas fa-edit" width="17" height="17"></i>
                                    </a>         
                                    <a asp-action="Delete" class="btn btn-outline-danger btn-sm align-self-center" asp-route-id="@Role.Id">
                                         <i class="fas fa-trash-alt" width="17" height="17"></i>
                                    </a>                
                            </td>
                        </tr>
                }
                    </tbody>
                </table>
                    }
                    else{
                       <div class="card mb-4">
                            <div class="card-header mb-4">
                                لا يوجد دور او مسؤولية بعد
                            </div>
                            <div class="card-body">
                                    <h6 class="card-title mb-4">
                                        استخدم الزر اعلاه لاضافة دور جديد
                                    </h6>
                            </div>
                      </div>
                    }
                   </div>                  
            </div>
        </div>
    </div>
 </div>