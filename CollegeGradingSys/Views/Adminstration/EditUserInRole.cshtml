@using CollegeGradingSys.ViewModels.Adminstration
@model List<UserRoleViewModel>

@{
    var roleId = ViewBag.roleId;
    ViewData["PageName"] = "حسابات المستخدمين";
    ViewData["SubPageName"] = "إضافة/حذف مستخدمين  لهذه المسؤولية";
}

<form   method="post">
    <div class=card>
        <div class="card-header">
            <h2>
                إضافة/حذف مستخدمين  لهذه المسؤولية
            </h2>
        </div>
         <div class="card-body">
             @for (var i = 0; i < Model.Count; i++)
            {
               <div class="form-check m-1" >
                   <input type="hidden" asp-for="@Model[i].UserId"  />
                   <input type="hidden" asp-for="@Model[i].UserName"  />                 
                   <input asp-for="@Model[i].IsSelected" class="form-check-input" />
                   <label class="form-check-label" asp-for="@Model[i].IsSelected">
                       @Model[i].EmployeeName
                   </label>
               </div>

            }
        </div>
         <div class="card-footer">
              <input type="submit" value="تعديل" class="btn col-2 btn-primary btn-sm" />
            <a class="btn btn-secondary   btn-sm" asp-action="EditRole" asp-route-id="@roleId">إلغاء الامر</a>
        </div>
    </div>
</form>