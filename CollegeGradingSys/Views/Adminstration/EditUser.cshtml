@section Scripts {
    <script>
        
    $("#BranchList").on("change", function () {           
    var url = '@Url.Content("~/")' + "Adminstration/GetDepartmentesDropDown";
    var ddlsource = "#BranchList";
    var selectedId = '';
    $.getJSON(url, { BranchID: $(ddlsource).val() }, function (data) {
        var items = '';

        $("#DepartmentesList").empty();
        $.each(data, function (i, row) {
            if (i == 0) {
                selectedId = row.value;
            }
            items += "<option value='" + row.value + "'>" + row.text + "</option>";
        });
        $("#DepartmentesList").html(items);
        //fullCourseList(selectedId);
    })

})
    </script>
   
}

   

