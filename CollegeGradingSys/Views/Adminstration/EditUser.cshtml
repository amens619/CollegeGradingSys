@model EditeUserViewModel
@using CollegeGradingSys.ViewModels.Adminstration
@using Microsoft.AspNetCore.Authorization

@inject IAuthorizationService authorizationService


@{
    ViewData["Title"] = "تعديل حساب ";
    ViewData["PageName"] = "حسابات المستخدمين";
    ViewData["SubPageName"] = "تعديل حساب";
}

 <!-- Main content -->
    <section class="content">
      <div class="container-fluid">  
          <div class="row">
            <div class="col-md-4 offset-md-1">
                <div class="card mb-4">
                     <form method="post" >
                         <div class="card-header ui-sortable-handle" style="cursor: move;">                  
                            <h3 class="card-title">
                                تعديل حساب المستخدم
                            </h3>
                            <div class="card-tools">                  
                                <button type="button" class="btn btn-success btn-sm" data-card-widget="collapse" title="Collapse">
                                    <i class="fas fa-minus"></i>
                                </button>
                            </div>

                        </div>
                            <!-- /.card-header -->
                        <div class="card-body">
                        <div asp-validation-summary="All" class="text-danger"></div>
                        <input asp-for="Id" type="hidden" class="form-control" />                                                    
                           
                            <div class="input-group mb-3">
                                    <input type="email" asp-for="Email"  class="form-control" placeholder="البريد الاكتروني" style="border-top-right-radius:0.25em  ; border-bottom-right-radius: 0.25em ;border-top-left-radius: 0; border-bottom-left-radius: 0;">
                                    <div class="input-group-append">
                                    <div class="input-group-text" style="border-top-left-radius:0.25em  ; border-bottom-left-radius: 0.25em ;border-top-right-radius: 0; border-bottom-right-radius: 0;">
                                        <span class="fas fa-envelope"></span>
                                    </div>
                                    </div>
                            </div>  
                            <a asp-action="ResetUserPassword" asp-controller="Adminstration" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">
                                تغيير كلمة المرور
                            </a>
                           
                        </div>
                        <div class="card-footer ">
                            <input type="submit" value="تعديل" class="btn col-2 btn-success btn-sm" />
                            <a class="btn btn-secondary  btn-sm" asp-action="ListUsers">إلغاء الامر</a>
                        </div>
                    </form>
                </div>
            </div>
       
              
           
            <div class="col-md-6">
                <div class="card p-0 ">
                    <div class="card-header ui-sortable-handle" style="cursor: move;">                  
                        <h3 class="card-title">
                            الادوار او المسؤوليات لهذا المستخدم
                        </h3>
                        <div class="card-tools">                  
                            <button type="button" class="btn btn-success btn-sm" data-card-widget="collapse" title="Collapse">
                                <i class="fas fa-minus"></i>
                            </button>
                        </div>
                    </div>
                        <!-- /.card-header -->
                    <div class="card-body">
                        @if(@Model.Roles.Any())
                        {
                            <table class="table table-bordered">
                                <thead class="table-light">
                                    <tr>                               
                                    <th scope="col" class=" col text-center" style="vertical-align: middle;">
                                        المسؤوليات لهذا المستخدم
                                    </th>
                                </tr>
                                </thead>
                                <tbody>
                                @foreach (var role in Model.Roles) 
                                {
                                    <tr>
                                        <td class="text-center" >
                                            @Html.DisplayFor(modelItem => role)
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class=" mb-4">
                                <h6 class="card-title mb-4">
                                    لا يوجد مسؤوليات لهذا المستخدم  
                                </h6>
                            </div>
                        }
                    </div> 
                    <div class="card-footer ">
                        @if((await authorizationService.AuthorizeAsync(User, "ManageUserRolesPolicy")).Succeeded)
                        {
                                <a asp-action="ManageUserRoles" asp-controller="Adminstration" class="btn btn-success" style="width:auto" asp-route-userId="@Model.Id">إضافة/حذف مسؤوليات</a>    
                        }  
                    </div>
                </div>
