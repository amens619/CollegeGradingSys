@using CollegeGradingSys.ViewModels.Adminstration
@model AdminResetPasswordViewModel

@{
    ViewData["Title"] = "تعديل كلمة المرور";
}

<section class="content">
    <div class="container-fluid mb-2">
        <div class="row">
            <div class="card card-outline card-success col-md-4 offset-md-4">
                <div class="card-header text-center">
                    <h3>إدارة المستخدمين</h3>
                </div>
                <div class="card-body">
                    <p class="login-box-msg">تعديل كلمة المرور للمستخدم: <strong>@Model.UserName</strong></p>

                    <form method="post" asp-action="ResetUserPassword">
                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="UserName" />

                        <div asp-validation-summary="All" class="text-danger"></div>

                        <div class="input-group mb-3">
                            <input type="password" asp-for="NewPassword" class="form-control" placeholder="كلمة المرور الجديدة" style="border-top-right-radius:0.25em  ; border-bottom-right-radius: 0.25em ;border-top-left-radius: 0; border-bottom-left-radius: 0;">
                            <div class="input-group-append">
                                <div class="input-group-text" style="border-top-left-radius:0.25em  ; border-bottom-left-radius: 0.25em ;border-top-right-radius: 0; border-bottom-right-radius: 0;">
                                    <span class="fas fa-lock"></span>
                                </div>
                            </div>
                        </div>

                        <div class="input-group mb-3">
                            <input type="password" asp-for="ConfirmPassword" class="form-control" placeholder="تأكيد كلمة المرور" style="border-top-right-radius:0.25em  ; border-bottom-right-radius: 0.25em ;border-top-left-radius: 0; border-bottom-left-radius: 0;">
                            <div class="input-group-append">
                                <div class="input-group-text" style="border-top-left-radius:0.25em  ; border-bottom-left-radius: 0.25em ;border-top-right-radius: 0; border-bottom-right-radius: 0;">
                                    <span class="fas fa-lock"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class=" col-12 mb-4">
                                <input type="submit" value="حفظ التعديل" class="btn btn-outline-success col-4 btn-sm" />
                                <a class="btn btn-secondary btn-sm " asp-controller="Adminstration" asp-action="EditUser" asp-route-id="@Model.UserId">إلغاء والرجوع</a>
                            </div>
                        </div>
                    </form>

                </div>
            </div>
        </div>

    </div>
</section>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}