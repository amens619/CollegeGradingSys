@model IEnumerable<IdentityUser> 
@using Microsoft.AspNetCore.Authorization

@inject IAuthorizationService authorizationService

@{
    ViewData["Title"] = "حسابات المستخدمين";
    ViewData["PageName"] = "حسابات المستخدمين";
    ViewData["SubPageName"] = "القائمة الرئسية";
}


 <!-- Main content -->
<section class="content">
    <div class="container-fluid">           
             @if ((await authorizationService.AuthorizeAsync(User, "CreateUserPolicy")).Succeeded)
             {
                <p>
                    @*<a asp-action="Create" class="btn btn-secondary  col-2 btn-sm "  ><i class="fas fa-plus mr-3"></i>جديد</a>*@
                    <a class="btn btn-secondary col-2 btn-sm" asp-action="Register" asp-controller="Account"><i class="fas fa-plus mr-3"></i>حساب جديد</a>
                </p>
             }
            <div class="card mb-4">
                <div class="card-body">
                    @if(@Model.Any()){
                        <table class="table table-bordered">
                         <thead >
                             <tr>                               
                                <th scope="col" class=" col th-font-size text-center" style="vertical-align: middle;width: 40%; ">
                                  اسم المستخدم
                                </th>
                                 <th scope="col" class=" col th-font-size text-center" style="vertical-align: middle;width: 40%; ">
                                   البريد الالكتروني
                                </th>                                
                                <th style="width: 20%;"></th>
                            </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model) 
                        {
                        <tr>

                            <td class="text-center">
                                <span class="td-font-size">@user.UserName</span>
                            </td>
                            <td class="text-center">
                                <span class="td-font-size">@user.Email</span>
                            </td>

                            <td class="text-center">
                                <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post">

                                    @if ((await authorizationService.AuthorizeAsync(User, "EditUserPolicy")).Succeeded && user.UserName != "Admin@Admin.com")
                                    {
                                        <a asp-action="EditUser" asp-controller="Adminstration" class="btn btn-outline-success btn-sm align-self-center" asp-route-id="@user.Id">
                                            <i class="fas fa-edit" width="17" height="17"></i>
                                        </a>
                                    }
                                    <span id="confirmDeleteSpan_@user.Id" style="display:none">
                                        <span>هل انت متأكد من رغبتك في حذف المستخدم ؟</span>
                                        <button type="submit" class="btn btn-danger btn-sm align-self-center">نعم</button>
                                        <a href="#" class="btn btn-success btn-sm align-self-center" onclick="confirmDelete('@user.Id',false)"> لا </a>
                                    </span>
                                    @if ((await authorizationService.AuthorizeAsync(User, "DeleteUserPolicy")).Succeeded && user.UserName != "Admin@Admin.com")
                                    {
                                        <span id="deleteSpan_@user.Id">
                                            <a href="#" class="btn btn-outline-danger btn-sm align-self-center" onclick="confirmDelete('@user.Id',true)">
                                                <i class="fas fa-trash-alt" width="17" height="17"></i>
                                            </a>
                                        </span>
                                    }


                                </form>

                            </td>
                        </tr>
                        }
                    </tbody>
                </table>
                    }
                    else{
                       <div class="card mb-4">
                            <div class="card-header mb-4">
                                لا يوجد حساب بعد
                            </div>
                            <div class="card-body">
                                    <h6 class="card-title mb-4">
                                        استخدم الزر اعلاه لاضافة حساب جديد
                                    </h6>
                            </div>
                      </div>
                    }
                   </div>                  
            </div>
        </div>
</section>

 @section Scripts {
    <script>
        function confirmDelete(uniquId,isDeleteClicked){
            var deleteSpan = 'deleteSpan_' + uniquId ;
            var confirmDeleteSpan ='confirmDeleteSpan_' + uniquId;

            if(isDeleteClicked){
                $('#' + deleteSpan).hide();
                $('#' + confirmDeleteSpan).show();
            } else {
                 $('#' + deleteSpan).show();
                $('#' + confirmDeleteSpan).hide();
            }
        }
    </script>
}