@model CollegeGradingSys.Models.StHighSchoolData

<!-- Modal -->
<div class="modal fade " id="add-contact" tabindex="-1" role="dialog" aria-labelledby="addContactLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                <h5 class="modal-title" id="addContactLabel">إضافة بيانات الثانوية</h5>
            </div>

            <hr />
            <div class="modal-body">
                <div class="modal-dialog modal-dialog-scrollable ">
                    <form asp-action="Create" class="row ">
                        <input name="IsValid" type="hidden" value="@ViewData.ModelState.IsValid.ToString()" />
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="form-group col-md-6">
                            <label asp-for="AcademicID" class="control-label"></label>
                            <input asp-for="AcademicID" readonly class="form-control" />
                        </div>
                        <div class="form-group col-md-6">
                            <label asp-for="CertificateType" class="control-label"></label>
                            <select asp-for="CertificateType" class="form-control text-center"
                                    asp-items="Html.GetEnumSelectList<CertificateType>()"></select>
                            <span asp-validation-for="CertificateType" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6">
                            <label asp-for="Average" class="control-label"></label>
                            <input asp-for="Average" class="form-control" />
                            <span asp-validation-for="Average" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6">
                            <label asp-for="Source" class="control-label"></label>
                            <input asp-for="Source" class="form-control" />
                            <span asp-validation-for="Source" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6">
                            <label asp-for="SeatNo" class="control-label"></label>
                            <input asp-for="SeatNo" class="form-control" />
                            <span asp-validation-for="SeatNo" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6">
                            <label asp-for="CertificateYear" class="control-label"></label>
                            <input asp-for="CertificateYear" class="form-control" />
                            <span asp-validation-for="CertificateYear" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6">
                            <label asp-for="HighSchoolName" class="control-label"></label>
                            <input asp-for="HighSchoolName" class="form-control" />
                            <span asp-validation-for="HighSchoolName" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6">
                            <label asp-for="Note" class="control-label"></label>
                            <input asp-for="Note" class="form-control" />
                            <span asp-validation-for="Note" class="text-danger"></span>
                        </div>

                    </form>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">إلغاء الأمر</button>
                <button type="button" class="btn btn-primary">حفظ</button>                
            </div>
        </div>
    </div>
</div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
