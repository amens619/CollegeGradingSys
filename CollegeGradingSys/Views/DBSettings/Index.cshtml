@model IEnumerable<CollegeGradingSys.Models.DBSettings>
@using Microsoft.AspNetCore.Authorization

@inject IAuthorizationService authorizationService
@{
    ViewData["Title"] = "الرئيسية";
    ViewData["PageName"] = "النسخ الاحتياطي لقاعدة البيانات";
    ViewData["SubPageName"] = "القائمة الرئسية";
}

 <!-- Main content -->
<section class="content">
    <div class="container-fluid">        
        @if ((await authorizationService.AuthorizeAsync(User, "CreateBackupPolicy")).Succeeded)
        {
            <p>
                @using (Html.BeginForm("Backup", "DBSettings", FormMethod.Post))
                { 
                    <div class="mb-4 ">                        
                            <input type="submit" value="اجراء نسخة احتياطية جديدة" class="btn btn-secondary btn-sm" />                           
                    </div>
                }
            </p>
        }
        <div class="card col-md-8 mb-4 ">
            <div class="card-body">
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th scope="col" class=" col-auto th-font-size text-center" style="vertical-align: middle;width: 80%;">
                                    @Html.DisplayNameFor(model => model.BackupName)
                            </th>
                            <th style="width: 20%;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model) {
                   
                                    <tr >    
                       
                                        <td class="text-center td-font-size" >
                                        @Html.DisplayFor(modelItem => item.BackupName)
                                    </td>
                      
                       
                                    <td class="text-center">   
                                            @if ((await authorizationService.AuthorizeAsync(User, "DeleteBackupPolicy")).Succeeded)
                                            {
                                                <a asp-action="Delete" class="btn btn-outline-danger btn-sm align-self-center" asp-route-id="@item.Id">
                                                             <i class="fas fa-trash-alt" width="17" height="17"></i>
                                                    </a>    
                                            }    
                                  
                         
                                    </td>
                                </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
