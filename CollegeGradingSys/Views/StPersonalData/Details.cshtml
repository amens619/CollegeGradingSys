@model CollegeGradingSys.Models.StPersonalData


@{
    ViewData["Title"] = "التفصيل";
}

<div class="card mb-4">
    <div class="card-body">
        <div class="bg-white">
            <h5 class="mb-4">  <span style="margin-left:6px;" data-feather="edit"></span>البيانات الشخصية للطالب</h5>
            <h6 class="m-1">التفصيل</h6>
            <hr class="mb-2 mt-0">
            <div class=" row my-5 col-md-12">

                <div class=" col-md-6">
                    <div class="card m-2">
                        <div class="card-title mx-2 mt-2">
                            <h6>البيانات الاساسية </h6>
                            <hr />
                        </div>
                        <div class="card-body row">
                            <div class="col-sm-4 my-2">
                                @Html.DisplayNameFor(model => model.AcademicID)
                            </div>
                            <div class="col-sm-7 my-2">
                                @Html.DisplayFor(model => model.AcademicID)
                            </div>
                            <div class="col-sm-4 my-2">
                                @Html.DisplayNameFor(model => model.StName)
                            </div>
                            <div class="col-sm-7 my-2">
                                @Html.DisplayFor(model => model.StName)
                            </div>
                            <div class="col-sm-4 my-2">
                                @Html.DisplayNameFor(model => model.IdentificatioNO)
                            </div>
                            <div class="col-sm-7 my-2">
                                @Html.DisplayFor(model => model.IdentificatioNO)
                            </div>
                            <div class="col-sm-4 my-2">
                                @Html.DisplayNameFor(model => model.Sex)
                            </div>
                            <div class="col-sm-7 my-2">
                                @Html.DisplayFor(model => model.Sex)
                            </div>
                            <div class="col-sm-4 my-2">
                                <span>مكان الميلاد ( </span>
                                @Html.DisplayNameFor(model => model.Birthcountry.CountryName)
                                <span>) </span>
                            </div>
                            <div class="col-sm-7 my-2">
                                @Html.DisplayFor(model => model.Birthcountry.CountryName)
                            </div>
                            <div class="col-sm-4 my-2">
                                <span>مكان الميلاد ( </span>
                                @Html.DisplayNameFor(model => model.BirthGovernorate.GovernorateName)
                                <span>) </span>
                            </div>
                            <div class="col-sm-7 my-2">
                                @Html.DisplayFor(model => model.BirthGovernorate.GovernorateName)
                            </div>
                            <div class="col-sm-4 my-2">
                                @Html.DisplayNameFor(model => model.BirthDate)
                            </div>
                            <div class="col-sm-7 my-2">
                                @Html.DisplayFor(model => model.BirthDate)
                            </div>
                            <div class="col-sm-4 my-2">
                                <span>سنة الالتحاق بالميلادي</span>
                            </div>
                            <div class="col-sm-7 my-2">
                                @Html.DisplayFor(model => model.EnrollmentYear.AcademicYearName)
                            </div>
                            <div class="col-sm-4 my-2">
                                <span>سنة الالتحاق بالهجري</span>
                            </div>
                            <div class="col-sm-7 my-2">
                                @Html.DisplayFor(model => model.EnrollmentYear.AcademicYearNameH)

                            </div>
                            <div class="my-2">
                                <a asp-action="Edit" class="btn btn-primary btn-sm align-self-center" asp-route-id="@Model.AcademicID">تعديل</a>
                            </div>
                        </div>
                    </div>
                </div>
                @if (@Model.StHighSchoolData != null)
                {
                    <div class="col-md-6">
                        <div class="card m-2  ">
                            <div class="card-title mx-2 mt-2">
                                <h6>بيانات شهادة الثانوية</h6>
                                <hr />
                            </div>
                            <div class="card-body row">
                                <div class="col-sm-4 my-2">
                                    @Html.DisplayNameFor(model => model.StHighSchoolData.CertificateType)
                                </div>
                                <div class="col-sm-7 my-2">
                                    @Html.DisplayFor(model => model.StHighSchoolData.CertificateType)
                                </div>
                                <div class="col-sm-4 my-2">
                                    @Html.DisplayNameFor(model => model.StHighSchoolData.Average)
                                </div>
                                <div class="col-sm-7 my-2">
                                    @Html.DisplayFor(model => model.StHighSchoolData.Average)
                                </div>
                                <div class="col-sm-4 my-2">
                                    @Html.DisplayNameFor(model => model.StHighSchoolData.Source)
                                </div>
                                <div class="col-sm-7 my-2">
                                    @Html.DisplayFor(model => model.StHighSchoolData.Source)
                                </div>
                                <div class="col-sm-4 my-2">
                                    @Html.DisplayNameFor(model => model.StHighSchoolData.SeatNo)
                                </div>
                                <div class="col-sm-7 my-2">
                                    @Html.DisplayFor(model => model.StHighSchoolData.SeatNo)
                                </div>
                                <div class="col-sm-4 my-2">
                                    @Html.DisplayNameFor(model => model.StHighSchoolData.CertificateYear)
                                </div>
                                <div class="col-sm-7 my-2">
                                    @Html.DisplayFor(model => model.StHighSchoolData.CertificateYear)
                                </div>
                                <div class="col-sm-4 my-2">
                                    @Html.DisplayNameFor(model => model.StHighSchoolData.HighSchoolName)
                                </div>
                                <div class="col-sm-7 my-2">
                                    @Html.DisplayFor(model => model.StHighSchoolData.HighSchoolName)
                                </div>
                                <div class="col-sm-4 my-2">
                                    @Html.DisplayNameFor(model => model.StHighSchoolData.Note)
                                </div>
                                <div class="col-sm-7 my-2">
                                    @Html.DisplayFor(model => model.StHighSchoolData.Note)
                                </div>
                                <div class="my-2">
                                    <!-- Modal placeholder -->
                                    <div id="modal-placeholder"></div>

                                    <button type="button" class="btn btn-primary btn-sm align-self-center" data-toggle="ajax-modal" data-target="#add-contact" data-url="@Url.Action("Edit","StHighSchoolData", new { id = Model.AcademicID })">
                                        تعديل
                                    </button>
                                    <button type="button" class="btn btn-danger align-self-center btn-sm" data-toggle="ajax-modal" data-target="#add-contact" data-url="@Url.Action("Delete","StHighSchoolData", new { id = Model.AcademicID })">
                                        حذف
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    @if (ViewData["AcademicID"] != null)
                    {
                        <p>

                        </p>
                    }
                }

            </div>
            <hr class="mb-2 mt-4">
            <div class="m-2">
                <a class="btn btn-secondary  btn-sm" asp-action="Index">القائمة الرئسية</a>
            </div>

        </div>
    </div>
</div>
