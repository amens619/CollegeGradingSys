@model IEnumerable<CollegeGradingSys.Models.StPersonalData>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.StName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IdentificatioNO)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Sex)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.BirthDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EnrollmentYearM)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EnrollmentYearH)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.StName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IdentificatioNO)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Sex)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.BirthDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EnrollmentYearM)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EnrollmentYearH)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.AcademicID">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.AcademicID">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.AcademicID">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
