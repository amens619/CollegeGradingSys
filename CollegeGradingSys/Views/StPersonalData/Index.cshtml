@model CollegeGradingSys.ViewModels.StPersonalDataFilteringIndexData
<link href="~/Content/PagedList.css" rel="stylesheet" type="text/css" />

@{
    ViewData["Title"] = "Index";
    ViewData["Controller"] = "StPersonalData";
    ViewData["Action"] = "Index";
}



<div class="card mb-4">

    <div class="card-body">
        <h5 class="card-title">البيانات الشخصية للطلاب</h5>
        <p>
            <a asp-action="Create">إضافة طالب جديد</a>
        </p>
        @using (Html.BeginForm("Index", "StPersonalData", FormMethod.Get))
        {
            <p>
                الاسم : @Html.TextBox("SearchString", ViewBag.CurrentFilter as string)
                رقم القيد : @Html.TextBox("SearchAcademicID", ViewBag.CurrentAcademicID as int?)


                <input type="submit" value="تصفية" class="btn btn-secondary btn-sm" />
                <a asp-action="Index" class="btn btn-secondary btn-sm" asp-route-id=-1>إلغاء التصفية</a>
            </p>
        }
    </div>
</div>
<div class="table-responsive">
    <table class="table table-bordered">
        <thead class="table-light">
            <tr>
                <th scope="col">
                    رقم القيد
                </th>
                <th scope="col" class="col-2" >
                    @Html.ActionLink("اسم الطالب", "Index", new { sortOrder = ViewBag.NameSortParm, currentFilter = ViewBag.CurrentFilter })
                </th>
                <th scope="col">
                    الرقم الوطني (الهوية )
                </th>
                <th scope="col">
                    @Html.ActionLink("الجنس", "Index", new { sortOrder = ViewBag.SexSortParm, currentFilter = ViewBag.CurrentFilter })
                </th>
                <th scope="col">
                    سنة الالتحاق ميلادي
                </th>
                <th scope="col">
                    سنة الالتحاق هجري
                </th>

                <th scope="col">
                    تاريخ الميلاد
                </th>
                <th scope="col">
                    نوع شهادة الثانوية
                </th>
                <th scope="col">
                    سنة الشهادة
                </th>

                <th scope="col">
                    المعدل (النسبة)
                </th>
                <th  class="col-3" scope="col"></th>
               
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.pagedResult.Data)
            {
                string selectedRow = "";
                if (item.AcademicID == (int?)ViewData["AcademicID"])
                {
                    selectedRow = "table-success";
                }
            <tr class="@selectedRow">
                <th scope="row">
                    @Html.DisplayFor(modelItem => item.AcademicID)
                </th>
                <td>
                    @Html.DisplayFor(modelItem => item.StName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.IdentificatioNO)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Sex)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.BirthDate)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.EnrollmentYearM)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.EnrollmentYearH)
                </td>
                @if (item.StHighSchoolData != null)
                {

                    <td>
                        @Html.DisplayFor(modelItem => item.StHighSchoolData.CertificateType)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.StHighSchoolData.CertificateYear)

                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.StHighSchoolData.Average)

                    </td>

                }
                else
                {
                    <!-- Modal placeholder -->
                    <div id="modal-placeholder"></div>

                    <!-- Button trigger modal -->
                   
            <td class="align-items-center" colspan="3">
                لا توجد بيانات شهادة الثانوية
                <button type="button" class="btn btn-outline-secondary align-self-center btn-sm" data-toggle="ajax-modal"  data-target="#add-contact" data-url="@Url.Action("Create","StHighSchoolData", new { id = item.AcademicID })">
                    إضافة
                </button>
                @*<a asp-action="Create" class="" asp-controller= asp-route-id="@item.AcademicID"></a>*@
            </td>



                }



                <td>
                    <a asp-action="AllStAcademicDatas" asp-controller="StAcademicData" class="btn btn-secondary btn-sm" asp-route-id="@item.AcademicID">السجل الاكاديمي</a>
                    <a asp-action="Details" class="btn btn-warning btn-sm" asp-route-id="@item.AcademicID">تفاصيل</a>
                    <a asp-action="Delete" class="btn btn-danger btn-sm" asp-route-id="@item.AcademicID">حذف</a>
                </td>
            </tr>
            }
        </tbody>
    </table>
</div>
<br />
<partial name="_PaginationPartial" model="Model.pagedResult" view-data="ViewData" />






