@model CollegeGradingSys.ViewModels.HomeIndexVM
@inject UserManager<IdentityUser> UserManager
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService authorizationService

@{
    ViewData["Title"] = "الرئيسية";
    ViewData["PageName"] = "لوحة التحكم";

    // 💡 ترتيب منطق النصوص العربية هنا يجعل كود الـ HTML في الأسفل نظيفاً جداً
    string studentsCountText = "";
    switch (Model.StudentsNO)
    {
        case 1: studentsCountText = "طالب واحد"; break;
        case 2: studentsCountText = "طالبين"; break;
        case int n when (n >= 3 && n <= 10): studentsCountText = $"{Model.StudentsNO} طلاب"; break;
        default: studentsCountText = $"{Model.StudentsNO} طالب"; break;
    }
}

<!-- إضافة ستايلات بسيطة للبطاقات لتظهر بشكل عصري -->
<style>
    .dash-card {
        border-radius: 15px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .dash-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        }

    .icon-circle {
        width: 65px;
        height: 65px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
    }
</style>

<!-- Main content -->
<section class="content mt-4">
    <div class="container-fluid">
        <div class="row">

            <!-- 📊 القسم الأيمن: الإحصائيات (يأخذ 8 أعمدة) -->
            <div class="col-lg-8">
                <div class="row">

                    <!-- 1. العام الأكاديمي -->
                    <div class="col-md-6 mb-4">
                        <div class="card dash-card shadow-sm border-0 h-100" style="border-right: 5px solid #17a2b8;">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="text-right">
                                        <p class="text-muted mb-1 fw-bold">العام الأكاديمي الحالي</p>
                                        <h4 class="fw-bold text-dark mb-0">@Model.AcademicYearName</h4>
                                    </div>
                                    <div class="icon-circle bg-light text-info shadow-sm">
                                        <i class="fas fa-calendar-check"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 2. الطلاب المسجلين -->
                    <div class="col-md-6 mb-4">
                        <div class="card dash-card shadow-sm border-0 h-100" style="border-right: 5px solid #28a745;">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="text-right">
                                        <p class="text-muted mb-1 fw-bold">الطلاب المسجلين</p>
                                        <!-- استخدام المتغير المنظم الذي جهزناه في الأعلى -->
                                        <h4 class="fw-bold text-dark mb-0">@studentsCountText</h4>
                                    </div>
                                    <div class="icon-circle bg-light text-success shadow-sm">
                                        <i class="fas fa-users"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 3. الطلاب الخريجين -->
                    <div class="col-md-6 mb-4">
                        <div class="card dash-card shadow-sm border-0 h-100" style="border-right: 5px solid #6f42c1;">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="text-right">
                                        <p class="text-muted mb-1 fw-bold">الطلاب الخريجين</p>
                                        <h4 class="fw-bold text-dark mb-0">82 طالب</h4>
                                    </div>
                                    <div class="icon-circle bg-light text-purple shadow-sm" style="color: #6f42c1;">
                                        <i class="fas fa-user-graduate"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 4. الطلاب المنسحبين -->
                    <div class="col-md-6 mb-4">
                        <div class="card dash-card shadow-sm border-0 h-100" style="border-right: 5px solid #dc3545;">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="text-right">
                                        <p class="text-muted mb-1 fw-bold">الطلاب المنسحبين</p>
                                        <h4 class="fw-bold text-dark mb-0">11 طالب</h4>
                                    </div>
                                    <div class="icon-circle bg-light text-danger shadow-sm">
                                        <i class="fas fa-user-minus"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- 🏛️ القسم الأيسر: بطاقة هوية الكلية (يأخذ 4 أعمدة) -->
            <div class="col-lg-4 mb-4">
                <div class="card dash-card shadow-sm border-0 h-100">
                    <div class="card-body text-center d-flex flex-column justify-content-center pt-5 pb-5">
                        <!-- شعار الجامعة -->
                        <div class="mb-4">
                            <img src="~/images/CollegeIcon.jpg" alt="شعار الجامعة" class="img-fluid  shadow-sm p-1 border" style="width: 140px; height: 140px; object-fit: cover;" />
                        </div>

                        <h4 class="fw-bold text-dark mb-2" style="font-family: 'Amiri', serif;">الجُمْهُوْرِيَّةُ اليَمَنِيَّة</h4>
                        <h6 class="text-primary fw-bold mb-1">جامعة الإيمان</h6>
                        <p class="text-muted mb-0">فرع حضرموت</p>

                        <hr class="w-50 mx-auto mt-4 mb-4" />

                        <div class="text-muted small">
                            <i class="fas fa-shield-alt text-success mr-1"></i> النظام مرخص ويعمل بشكل سليم
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>
<!-- /.content -->