@using CollegeGradingSys.ViewModels.Nationality
@model NationalityGovernorateViewModel

@{
    ViewData["Title"] = "التعديل";
    ViewData["PageName"] = "إدارة المحافظات /المناطق";
    //ViewData["SubPageName"] = "القائمة الرئسية";
}

}

<!-- Main content -->
<section class="content">
    <div class="container-fluid">
        <form asp-action="Edit">
            @if (ViewBag.Message != null)
            {
                <h5 class="alert alert-danger">@ViewBag.Message</h5>
            }
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="row">
                <div class="col-md-8 px-0 offset-md-2">
                    <div class="card">
                        <div class="card-header ui-sortable-handle" style="cursor: move;">
                            <h3 class="card-title">
                                التعديل
                            </h3>
                        </div>
                        <!-- /.card-header -->
                        <div class="card-body">
                            <div class="row">
                                <div class="form-group col-md-6">
                                    <label asp-for="GovernorateName" class="control-label"></label>
                                    <input asp-for="GovernorateName" class="form-control" />
                                    <span asp-validation-for="GovernorateName" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-6">
                                    <label asp-for="NationalityId" class="control-label"></label>
                                    <select asp-for="NationalityId" class="form-control text-center"
                                            asp-items="@(new SelectList(Model.Nationalities, "Id", "Name"))"> </select>                                   
                                    <span asp-validation-for="NationalityId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer">

                            <input type="submit" value="حفظ" class="col-2 btn btn-success btn-sm" />
                            <a class="btn btn-secondary  btn-sm" asp-action="Index">القائمة الرئسية</a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
