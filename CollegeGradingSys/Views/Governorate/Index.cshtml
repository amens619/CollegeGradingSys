@model cloudscribe.Pagination.Models.PagedResult<Governorate>

@{
    ViewData["Title"] = "Index";
    ViewData["Controller"] = "Governorate";
    ViewData["Action"] = "Index";
}
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                الدولة
            </th>
            <th>
                المحافظة
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Data)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Nationality.CountryName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.GovernorateName)
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>



<partial name="_PaginationPartial" model="Model" view-data="ViewData" />
