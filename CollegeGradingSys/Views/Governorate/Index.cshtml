@using cloudscribe.Pagination.Models;
@model cloudscribe.Pagination.Models.PagedResult<CollegeGradingSys.ViewModels.Governorate.GovernorateIndexVM>

@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService authorizationService

@{
    ViewData["Title"] = "إدارة المحافظات /المناطق";
    ViewData["Controller"] = "Governorate";
    ViewData["Action"] = "Index";
}


<!-- Main content -->
<section class="content">
    <div class="container-fluid">
        <p>
            @if ((await authorizationService.AuthorizeAsync(User, "CreateGovernoratePolicy")).Succeeded)
            {
                <a asp-action="Create" class="btn btn-secondary  col-2 btn-sm "><i class="fas fa-plus mr-3"></i>جديد</a>
            }

        </p>
        <div class="card  col-md-10 mb-4">
            <div class="card-body">
                <table class="table table-bordered">
                    <thead>
                        <tr>

                            <th scope="col" class=" col  th-font-size text-center" style="vertical-align: middle;width: 40%;">
                                المحافظة/المنطقة
                            </th>
                            <th scope="col" class=" col  th-font-size text-center" style="vertical-align: middle;width: 40%;">
                                الدولة
                            </th>
                            <th style="width: 20%;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Data)
                        {
                            <tr>
                                <td class="text-center td-font-size">
                                    @Html.DisplayFor(modelItem => item.GovernorateName)
                                </td>
                                <td class="text-center td-font-size">
                                    @Html.DisplayFor(modelItem => item.NationalityName)
                                </td>
                                <td class="text-center">
                                    @if ((await authorizationService.AuthorizeAsync(User, "EditGovernoratePolicy")).Succeeded)
                                    {
                                        <a asp-action="Edit" class="btn btn-outline-success btn-sm align-self-center" asp-route-id="@item.Id">
                                            <i class="fas fa-edit" width="17" height="17"></i>
                                        </a>
                                    }
                                    @if ((await authorizationService.AuthorizeAsync(User, "DeleteGovernoratePolicy")).Succeeded)
                                    {
                                        <a asp-action="Delete" class="btn btn-outline-danger btn-sm align-self-center" asp-route-id="@item.Id">
                                            <i class="fas fa-trash-alt" width="17" height="17"></i>
                                        </a>
                                    }
                                </td>

                            </tr>
                        }
                    </tbody>
                </table>

                <partial name="_PaginationPartial" model="Model" view-data="ViewData" />


            </div>
        </div>
    </div>
</section>