@model CollegeGradingSys.ViewModels.NationalityGovernorateViewModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>NationalityGovernorateViewModel</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            @if (ViewBag.Message != null)
            {
                <h5 class="alert alert-danger">@ViewBag.Message</h5>
            }
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="GovernorateName" class="control-label"></label>
                <input asp-for="GovernorateName" class="form-control" />
                <span asp-validation-for="GovernorateName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NationalityId" class="control-label"></label>
                <select asp-for="NationalityId" class="form-control text-center"
                        asp-items="@(new SelectList(Model.Nationalities,"Id","CountryName"))"></select>
                <span asp-validation-for="NationalityId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
