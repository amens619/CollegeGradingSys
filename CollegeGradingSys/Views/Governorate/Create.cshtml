@model CollegeGradingSys.ViewModels.NationalityGovernorateViewModel


@{
    ViewData["Title"] = "إضافة محافظة/ منطقة";
}

<div class="card mb-4">
    <div class="card-body">
        <div class="bg-white">
            <h5 class="mb-4">  <span style="margin-left:6px;" data-feather="plus"></span>إدارة المحافظات /المناطق</h5>
            <h6 class="m-1">إضافة محافظة/ منطقة</h6>
            <hr class="mb-4 mt-0">
            <div class="row col-md-12">
                <form asp-action="Create">
                    @if (ViewBag.Message != null)
                    {
                        <h5 class="alert alert-danger">@ViewBag.Message</h5>
                    }
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="row">
                        <div class="form-group col-md-6">
                            <label asp-for="GovernorateName" class="control-label"></label>
                            <input asp-for="GovernorateName" class="form-control" />
                            <span asp-validation-for="GovernorateName" class="text-danger"></span>
                        </div>
                        <div class="form-group col-md-6">
                            <label asp-for="NationalityId" class="control-label"></label>
                            <select asp-for="NationalityId" class="form-control text-center"
                                    asp-items="@(new SelectList(Model.Nationalities,"Id","CountryName"))"></select>
                            <span asp-validation-for="NationalityId" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="form-group mt-4">
                        <input type="submit" value="إضافة" class="btn col-2 btn-primary btn-sm" />
                        <a class="btn btn-secondary  btn-sm" asp-action="Index">القائمة الرئسية</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
