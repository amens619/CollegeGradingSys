@model CollegeGradingSys.ViewModels.CollegeDepartmentViewModel

@{
    ViewData["Title"] = "إضافة قسم جديد";
    ViewData["PageName"] = "إدارة الأقسام";
    //ViewData["SubPageName"] = "إضافة قسم جديد";

}

<!-- Main content -->
<section class="content">
    <div class="container-fluid">
        <form asp-action="Create">
            @if (ViewBag.Message != null)
            {
                <h5 class="alert alert-danger">@ViewBag.Message</h5>
            }
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row">
                <div class="col-md-8 px-0 offset-md-2">
                    <div class="card">
                        <div class="card-header ui-sortable-handle" style="cursor: move;">
                            <h3 class="card-title">
                                إضافة قسم جديد
                            </h3>
                        </div>
                        <!-- /.card-header -->
                        <div class="card-body">
                            <div class="row">
                                <div class="form-group col-md-6">
                                    <label asp-for="DepartmentName" class="control-label"></label>
                                    <input asp-for="DepartmentName" class="form-control" placeholder="ادخل اسم القسم" />
                                    <span asp-validation-for="DepartmentName" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-6">
                                    <label asp-for="CollegeId" class="control-label"></label>
                                    <select asp-for="CollegeId" class="form-control text-center"
                                            asp-items="@(new SelectList(Model.Colleges,"Id","CollegeName"))"></select>
                                    <span asp-validation-for="CollegeId" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer">
                           
                                <input type="submit" value="إضافة" class="btn col-2 btn-success btn-sm" />
                                <a class="btn btn-secondary  btn-sm" asp-action="Index">القائمة الرئسية</a>
                           
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
