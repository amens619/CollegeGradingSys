@model CollegeGradingSys.ViewModels.CreateStAcademicDataDataViewModel
@{
    ViewData["Title"] = "التعديل";
    ViewData["PageName"] = "البيانات الاكاديمية للطلاب";
    //ViewData["SubPageName"] = "تعديل فصل دراسي";
}

<!-- Main content -->
<section class="content">
    <div class="container-fluid">
        <div class="card mb-4">
            <div class="card-body">
                <div class="row ">
                    <div class="form-group col-md-6">
                        <label asp-for="AcademicID" class="control-label"></label>
                        <input asp-for="AcademicID" readonly class="form-control" />
                    </div>
                    <div class="form-group col-md-6">
                        <label asp-for="StName" class="control-label"></label>
                        <input asp-for="StName" readonly class="form-control" />
                    </div>
                </div>
            </div>
        </div>        
        <form asp-action="Edit" >
            @if (ViewBag.Message != null)
            {
                <h5 class="alert alert-danger">@ViewBag.Message</h5>
            }
            <input asp-for="AcademicID" hidden class="form-control" />
            <input asp-for="Id" hidden class="form-control" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="row">
                <div class="col-md-12 ">
                    <div class="card">
                        <div class="card-header ">
                            <h3 class="card-title">
                                تعديل فصل دراسي
                            </h3>
                        </div>
                        <!-- /.card-header -->
                        <div class="card-body">
                            <div class="row">
                                <div class="form-group col-md-3">
                                    <label asp-for="AcademicYearId" class="control-label"></label>
                                    <select id="AcademicYearList" disabled asp-for="AcademicYearId" class="form-control text-center"
                                            asp-items="ViewBag.AcademicYearId"></select>

                                </div>
                                <div class="form-group col-md-3">
                                    <label asp-for="BatchId" class="control-label"></label>
                                    <select id="BatchList" disabled asp-for="BatchId" class="form-control text-center"
                                            asp-items="ViewBag.BatchId"></select>
                                </div>
                                <div class="form-group col-md-3">
                                    <label asp-for="StLevel" class="control-label"></label>
                                    <select asp-for="StLevel" disabled class="form-control text-center"
                                            asp-items="Html.GetEnumSelectList<Level>()"></select>
                                    <span asp-validation-for="StLevel" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-3">
                                    <label asp-for="Term" class="control-label"></label>
                                    <select asp-for="Term" disabled class="form-control text-center"
                                            asp-items="Html.GetEnumSelectList<Term>()"></select>
                                    <span asp-validation-for="Term" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-3">
                                    <label asp-for="StudyType" class="control-label"></label>
                                    <select id="StudyType" asp-for="StudyType " class="form-control text-center"
                                            asp-items="Html.GetEnumSelectList<StudyType>()"></select>
                                    <span asp-validation-for="StudyType" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-3">
                                    <label asp-for="StStatus" class="control-label"></label>
                                    <select id="StStatusList" asp-for="StStatus" class="form-control text-center"
                                            asp-items="Html.GetEnumSelectList<StStatus>()"></select>
                                    <span asp-validation-for="StStatus" class="text-danger"></span>
                                </div>

                                <div class="form-group col-md-3">
                                    <label asp-for="Average" class="control-label"></label>
                                    <input id="AverageInput" asp-for="Average" class="form-control" />
                                    <span asp-validation-for="Average" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-3">
                                    <label asp-for="Valuation" class="control-label"></label>
                                    <select id="Valuationlist" asp-for="Valuation" class="form-control text-center"
                                            asp-items="Html.GetEnumSelectList<Valuation>()"></select>
                                    <span asp-validation-for="Valuation" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-3">
                                    <label asp-for="GPA" class="control-label"></label>
                                    <input id="GPAInput" asp-for="GPA" class="form-control" />
                                    <span asp-validation-for="GPA" class="text-danger"></span>
                                </div>

                            </div>
                        </div>

                        <div class="card-footer">
                            <input type="submit" value="حفظ" class="col-2 btn btn-success btn-sm" />
                            <a class="btn btn-secondary btn-sm" asp-action="AllStAcademicDatas" asp-route-id="@Model.AcademicID">السجل الاكاديمي</a>
                            <a class="btn btn-secondary  btn-sm" asp-route-IsSelectCurrentYear="True" asp-action="Index">القائمة الرئسية</a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>   
</section>
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(document).ready(function () {
            if ($(StStatusList).val() != 1 && $(StStatusList).val() != 5) {
                $("#Valuationlist").val(0);
                $("#AverageInput").val("");
                $("#GPAInput").val("");
                $("#Valuationlist").attr("disabled", "disabled");
                $("#AverageInput").attr("disabled", "disabled");
                $("#GPAInput").attr("disabled", "disabled");
            }
            $("#StStatusList").on("change", function () {
                if ($(StStatusList).val() == 1 || $(StStatusList).val() == 5) {
                    $("#Valuationlist").removeAttr("disabled");
                    $("#AverageInput").removeAttr("disabled");
                    $("#GPAInput").removeAttr("disabled");
                }
                else {
                    $("#Valuationlist").val(0);
                    $("#AverageInput").val("");
                    $("#GPAInput").val("");
                    $("#Valuationlist").attr("disabled", "disabled");
                    $("#AverageInput").attr("disabled", "disabled");
                    $("#GPAInput").attr("disabled", "disabled");
                }
            })
        })
    </script>
}
