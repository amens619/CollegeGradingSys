@using CollegeGradingSys.Models.Enums
@model CollegeGradingSys.ViewModels.StAcademic.CreateStAcademicDataDataViewModel

@{
    ViewData["Title"] = "تقيد الطالب";
}

<div class="card mb-4">
    <div class="card-body">
        <div class="bg-white">
            <h5 class="mb-4">  <span style="margin-left:6px;" data-feather="plus"></span>البيانات الاكاديمية للطلاب</h5>
            <h6 class="m-1">تقيد الطالب</h6>
            <hr class="mb-4 mt-0">
            <div class="card mb-4">

                <div class="card-body">
                    <div class="row">
                        <div class="form-group col-md-6">
                            <label asp-for="AcademicID" class="control-label"></label>
                            <input asp-for="AcademicID" readonly class="form-control text-center" />
                        </div>
                        <div class="form-group col-md-6">
                            <label asp-for="StName" class="control-label"></label>
                            <input asp-for="StName" readonly class="form-control text-center" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="card mb-4">
                <div class="card-body">
                    <h6 class="m-1">البيانات الحالية للطالب </h6>
                    <hr class="mb-1 mt-0">
                    <div class="row">
                        <div class="form-group col-md-3">
                            <label asp-for="preSpecialization" class="control-label"></label>
                            <input asp-for="preSpecialization" readonly class="form-control text-center" />
                        </div>
                        <div class="form-group col-md-3">
                            <label asp-for="preLevel" class="control-label"></label>
                            <input asp-for="preLevel" readonly class="form-control text-center" />
                        </div>
                        <div class="form-group col-md-3">
                            <label asp-for="preStStatus" class="control-label"></label>
                            <input asp-for="preStStatus" readonly class="form-control text-center" />
                        </div>
                        <div class="form-group col-md-3">
                            <label asp-for="preGPA" class="control-label"></label>
                            <input asp-for="preGPA" readonly class="form-control text-center" />
                        </div>

                    </div>

                </div>
            </div>
            <div class="row col-md-12">
                <form asp-action="Create" class="row g-3">
                    @if (ViewBag.Message != null)
                    {
                        <h5 class="alert alert-danger">@ViewBag.Message</h5>
                    }
                    <input asp-for="AcademicID" hidden class="form-control" />
                    <input asp-for="Id" hidden class="form-control" value="0" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="form-group col-md-3">
                        <label asp-for="AcademicYearId" class="control-label"></label>
                        <select id="AcademicYearList" disabled asp-for="AcademicYearId" class="form-control text-center"
                                asp-items="ViewBag.AcademicYearId"></select>

                    </div>

                    <div class="form-group col-md-3">
                        <label asp-for="BatchId" class="control-label"></label>
                        <select id="BatchList" asp-for="BatchId" class="form-control text-center"
                                asp-items="ViewBag.BatchId"></select>
                    </div>
                    
                    <div class="form-group col-md-3">
                        <label asp-for="StLevel" class="control-label"></label>
                        <input asp-for="StLevel" readonly class="form-control text-center" />
                    </div>
                    <div class="form-group col-md-3">
                        <label asp-for="StudyType" class="control-label"></label>
                        <select asp-for="StudyType" class="form-control text-center"
                                asp-items="Html.GetEnumSelectList<StudyType>()"></select>
                    </div>
                    @*<div class="form-group col-md-3">
            <label asp-for="StStatus" class="control-label"></label>
            <select id="StStatusList" asp-for="StStatus" class="form-control text-center"
                    asp-items="Html.GetEnumSelectList<StStatus>()"></select>
            <span asp-validation-for="StStatus" class="text-danger"></span>
        </div>*@


                    <div class="form-group mt-4">
                        <input type="submit" value="تقييد" class="btn col-2 btn-primary btn-sm" />
                        <a class="btn btn-secondary btn-sm" asp-action="StudentAcademicHistory" asp-route-academicID="@Model.AcademicID">السجل الاكاديمي</a>
                        <a class="btn btn-secondary  btn-sm" asp-action="Index">القائمة الرئسية</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        $(document).ready(function () {
            if ($(StStatusList).val() != 0) {
                $("#Valuationlist").val(0);
                $("#AverageInput").val("");
                $("#GPAInput").val("");
                $("#Valuationlist").attr("disabled", "disabled");
                $("#AverageInput").attr("disabled", "disabled");
                $("#GPAInput").attr("disabled", "disabled");
            }
            $("#StStatusList").on("change", function () {
                if ($(StStatusList).val() == 0) {
                    $("#Valuationlist").removeAttr("disabled");
                    $("#AverageInput").removeAttr("disabled");
                    $("#GPAInput").removeAttr("disabled");
                }
                else {
                    $("#Valuationlist").val(0);
                    $("#AverageInput").val("");
                    $("#GPAInput").val("");
                    $("#Valuationlist").attr("disabled", "disabled");
                    $("#AverageInput").attr("disabled", "disabled");
                    $("#GPAInput").attr("disabled", "disabled");
                }


            })

        })
    </script>
}
