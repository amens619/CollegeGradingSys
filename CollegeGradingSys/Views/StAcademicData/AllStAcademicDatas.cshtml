@model CollegeGradingSys.ViewModels.StAcademicDataDataViewModel

@{
    ViewData["Title"] = "السجل التفصيلي ";
}



<div class="card mb-4">

    <div class="card-body">
        <div class="bg-white">
            <h5 class="mb-4">  <span style="margin-left:6px;" data-feather="list"></span>البيانات الاكاديمية للطلاب</h5>
            <h6 class="m-1">السجل الاكاديمي التفصيلي للطالب</h6>
            <hr class="mb-4 mt-0">
            <p>
                @if (Model.IsCanRegisterInCurrentYear)
                {
                    <a asp-action="Create" class="btn btn-secondary btn-sm" asp-route-id="@Model.AcademicID">تقييد الطالب</a>
                }
            </p>
            @if (ViewBag.Message != null)
            {
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    @ViewBag.Message

                </div>               
            }
            <div class="card mb-4">

                <div class="card-body">
                    <div class="row">
                        <div class="form-group col-md-6">
                            <label asp-for="AcademicID" class="control-label"></label>
                            <input asp-for="AcademicID" readonly class="form-control" />
                        </div>
                        <div class="form-group col-md-6">
                            <label asp-for="StName" class="control-label"></label>
                            <input asp-for="StName" readonly class="form-control" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="card mb-4">

                <div class="card-body">
                    <div class="bg-white">
                        <div class=" container">
                            <span class="badge bg-primary  "> مقيد</span>
                            <span class="badge bg-info  ">ناجح</span>
                            <span class="badge bg-danger  ">راسب</span>
                            <span class="badge bg-secondary  ">منحسب</span>
                            <span class="badge bg-warning  ">موقف قيد</span>
                            <span class="badge bg-success  ">متخرج</span>
                        </div>
                        <hr class="my-4">
                        <div class="table-responsive">
                            <table class="table  table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th th scope="col" class=" col-1 text-center" style="vertical-align: middle;">
                                            العام الدراسي
                                        </th>
                                        <th th scope="col" class=" col-1 text-center" style="vertical-align: middle;">
                                            الدفعة
                                        </th>
                                        <th th scope="col" class=" col-1 text-center" style="vertical-align: middle;">
                                            المستوى
                                        </th>
                                        <th th scope="col" class=" col-1 text-center" style="vertical-align: middle;">
                                            الفصل الدراسي
                                        </th>
                                        <th th scope="col" class=" col-1 text-center" style="vertical-align: middle;">
                                            نظام الدراسة
                                        </th>
                                        <th th scope="col" class=" col-1 text-center" style="vertical-align: middle;">
                                            النسبة
                                        </th>
                                        <th th scope="col" class=" col-1 text-center" style="vertical-align: middle;">
                                            التقدير
                                        </th>
                                        <th th scope="col" class=" col-1 text-center" style="vertical-align: middle;">
                                            المعدل التراكمي
                                        </th>
                                        <th th scope="col" class=" col-1 text-center" style="vertical-align: middle;">
                                            حالة الطالب
                                        </th>
                                        <th th scope="col" class=" col-3 text-center" style="vertical-align: middle;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.StAcademicDatas)
                                    {
                                        <tr>
                                            <td class="text-center" style="vertical-align: middle;">
                                                @Html.DisplayFor(modelItem => item.AcademicYear.AcademicYearName)
                                            </td>
                                            <td class="text-center" style="vertical-align: middle;">
                                                @Html.DisplayFor(modelItem => item.Batch.BatchName)
                                            </td>
                                            <td class="text-center" style="vertical-align: middle;">
                                                @Html.DisplayFor(modelItem => item.StLevel)
                                            </td>
                                            <td class="text-center" style="vertical-align: middle;">
                                                @Html.DisplayFor(modelItem => item.Term)
                                            </td>
                                            <td class="text-center" style="vertical-align: middle;">
                                                @Html.DisplayFor(modelItem => item.StudyType)
                                            </td>
                                            <td class="text-center" style="vertical-align: middle;">
                                                @Html.DisplayFor(modelItem => item.Average)
                                            </td>
                                            <td class="text-center" style="vertical-align: middle;">
                                                @Html.DisplayFor(modelItem => item.Valuation)
                                            </td>
                                            <td class="text-center" style="vertical-align: middle;">
                                                @Html.DisplayFor(modelItem => item.GPA)
                                            </td>
                                            <td class="text-center" style="vertical-align: middle;">
                                                @switch (item.StStatus)
                                                {
                                                    case StStatus.مقيد:
                                                        <span class="badge bg-primary">@item.StStatus</span>
                                                        break;
                                                    case StStatus.ناجح:
                                                        <span class="badge bg-info">@item.StStatus</span>
                                                        break;
                                                    case StStatus.راسب:
                                                        <span class="badge bg-danger ">@item.StStatus</span>
                                                        break;
                                                    case StStatus.منحسب:
                                                        <span class="badge bg-secondary">@item.StStatus</span>
                                                        break;
                                                    case StStatus.موقف_قيد:
                                                        <span class="badge bg-warning ">@item.StStatus</span>
                                                        break;
                                                    case StStatus.متخرج:
                                                        <span class="badge bg-success">@item.StStatus</span>
                                                        break;
                                                }
                                            </td>
                                            <td class="text-center" style="vertical-align: middle;">
                                                <a asp-action="AllStCourseGrade" asp-controller="CourseGrade" class="btn btn-secondary btn-sm" asp-route-id="@item.Id">الدرجات</a>
                                                @if (item.AcademicYear.IsCurrentYear == true)
                                                {
                                                    <a asp-action="Edit" class="btn btn-primary btn-sm" asp-route-id="@item.Id">تعديل</a>
                                                }
                                                @*<a asp-action="Details" class="btn btn-warning btn-sm" asp-route-id="@item.Id">تفاصيل</a>*@
                                                @if (item.StStatus == StStatus.متخرج)
                                                {
                                                    <a class="btn btn-dark btn-sm" asp-route-id="@item.Id">شهادة التخرج</a>
                                                    <a class="btn btn-dark btn-sm" asp-route-id="@item.Id">افادة</a>
                                                }
                                                @if (item.StStatus == StStatus.مقيد)
                                                {
                                                    <a class="btn btn-dark btn-sm" asp-route-id="@item.Id">تأكيد الدراسة</a>
                                                }
                                                @if (item.StStatus == StStatus.ناجح && item.StLevel == Level.الشامل)
                                                {
                                                    <a class="btn btn-dark btn-sm" asp-route-id="@item.Id">افادة بعد الشامل</a>
                                                }
                                                @if (item.StStatus == StStatus.ناجح && item.StLevel == Level.السابع)
                                                {
                                                    <a class="btn btn-dark btn-sm" asp-route-id="@item.Id">افادة ثلاثة سنوات</a>
                                                }

                                                @*<a asp-action="Delete" class="btn btn-danger btn-sm" asp-route-id="@item.Id">حذف</a>*@
                                            </td>


                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
   
</script>