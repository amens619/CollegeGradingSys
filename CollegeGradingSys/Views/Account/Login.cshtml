@using CollegeGradingSys.ViewModels.Account
@model LoginViewModel

@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "تسجيل الدخول";
}

<!-- استخدام Flexbox لتوسيط الشاشة في منتصف الصفحة تماماً -->
<section class="content d-flex justify-content-center align-items-center" style="min-height: 85vh;">
    <div class="container-fluid">

        <!-- 🟢 عرض رسائل الأخطاء بنفس تصميم شاشة التفعيل -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="row justify-content-center mb-4">
                <div class="col-md-12 col-lg-10">
                    <div class="alert alert-danger alert-dismissible fade show text-right shadow-sm" role="alert" style="border-radius: 10px;">
                        <button type="button" class="close float-left" data-dismiss="alert" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                        <h6 class="fw-bold mb-2">
                            <i class="fas fa-exclamation-triangle ml-1"></i> عذراً، يرجى التأكد من:
                        </h6>
                        <div asp-validation-summary="All" class="mb-0" style="list-style-type: none; padding-right: 0;"></div>
                    </div>
                </div>
            </div>
        }

        <div class="row justify-content-center">
            <!-- استخدام col-lg-4 لجعل المربع بحجم أنيق ومناسب لشاشات الكمبيوتر -->
            <div class="col-md-12 col-lg-12">
                <div class="card card-outline card-success shadow-lg" style="border-radius: 15px; border-top-width: 4px;">
                    <div class="card-header bg-white text-center pt-4 pb-2" style="border-radius: 15px 15px 0 0;">
                        <div class="text-success mb-2">
                            <i class="fas fa-user-lock fa-3x"></i>
                        </div>
                        <h3 class="card-title w-100 fw-bold float-none text-dark" style="font-size: 1.5rem;">
                            نظام إدارة الدرجات
                        </h3>
                        <p class="text-muted mt-2 mb-0" style="font-size: 0.95rem;">قم بتسجيل الدخول لبدء الجلسة</p>
                    </div>

                    <form method="post">
                        @Html.AntiForgeryToken()

                        <div class="card-body px-4 py-4 text-right">

                            <!-- الإيميل -->
                            <div class="form-group mb-4">
                                <label asp-for="Email" class="control-label fw-bold mb-2">البريد الإلكتروني:</label>
                                <div class="input-group input-group-lg shadow-sm" dir="ltr">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-white"><i class="fas fa-envelope text-success"></i></span>
                                    </div>
                                    <input asp-for="Email" class="form-control text-left" placeholder="example@domain.com" autocomplete="off" />
                                </div>
                            </div>

                            <!-- كلمة المرور -->
                            <div class="form-group mb-3">
                                <label asp-for="Password" class="control-label fw-bold mb-2">كلمة المرور:</label>
                                <div class="input-group input-group-lg shadow-sm" dir="ltr">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-white"><i class="fas fa-lock text-success"></i></span>
                                    </div>
                                    <input asp-for="Password" class="form-control text-left" placeholder="••••••••" autocomplete="off" />
                                </div>
                            </div>

                            <!-- تذكرني + نسيت كلمة المرور (في سطر واحد) -->
                            <div class="d-flex justify-content-between align-items-center mt-4" dir="rtl">
                                <div class="custom-control custom-checkbox">
                                    <!-- تغيير لون الـ Checkbox للأخضر ليتناسب مع الثيم -->
                                    <input class="custom-control-input custom-control-input-success" asp-for="RememberMe" type="checkbox" id="RememberMe">
                                    <label for="RememberMe" class="custom-control-label fw-bold" style="cursor: pointer; padding-top: 2px;">تذكرني</label>
                                </div>
                                <div>
                                    <a href="forgot-password.html" class="text-success fw-bold text-decoration-none">
                                        <small><i class="fas fa-question-circle ml-1"></i>نسيت كلمة المرور؟</small>
                                    </a>
                                </div>
                            </div>

                        </div>

                        <!-- زر الدخول -->
                        <div class="card-footer text-center bg-white pb-4 pt-0" style="border-radius: 0 0 15px 15px; border-top: none;">
                            <button type="submit" class="btn btn-success btn-lg shadow w-100" style="border-radius: 30px; font-weight: bold; font-size: 1.1rem;">
                                تسجيل الدخول <i class="fas fa-sign-in-alt mr-2"></i>
                            </button>
                        </div>
                    </form>
                </div>

                <!-- رسالة حقوقية أسفل المربع -->
                <div class="text-center mt-3 text-muted">
                    <small><i class="fas fa-copyright ml-1"></i> جميع الحقوق محفوظة - نظام إدارة الدرجات.</small>
                </div>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}