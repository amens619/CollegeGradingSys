@using CollegeGradingSys.ViewModels.Account
@model RegisterViewModel

@{
    ViewData["Title"] = "تسجيل مستخدم جديد";
}

<!-- Main content -->
<section class="content mt-4">
    <div class="container-fluid">

        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card card-outline card-success shadow-lg" style="border-radius: 15px; border-top-width: 4px;">
                    <div class="card-header bg-white text-center pt-4 pb-2" style="border-radius: 15px 15px 0 0;">
                        <div class="text-success mb-2">
                            <i class="fas fa-user-plus fa-3x"></i>
                        </div>
                        <h3 class="card-title w-100 fw-bold float-none text-dark" style="font-size: 1.5rem;">
                            حسابات المستخدمين
                        </h3>
                        <p class="text-muted mt-2 mb-0" style="font-size: 0.95rem;">إضافة مستخدم جديد للنظام</p>
                    </div>

                    <form method="post">
                        @Html.AntiForgeryToken()

                        <div class="card-body px-4 py-4 text-right">

                            <!-- 🛑 عرض رسائل الأخطاء العامة هنا -->
                            <div asp-validation-summary="All" class="text-danger fw-bold mb-3" style="list-style-type: none; padding-right: 0;"></div>

                            <!-- البريد الإلكتروني -->
                            <div class="form-group mb-4">
                                <label asp-for="Email" class="control-label fw-bold mb-2">البريد الإلكتروني:</label>
                                <div class="input-group input-group-lg shadow-sm" dir="ltr">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-white"><i class="fas fa-envelope text-success"></i></span>
                                    </div>
                                    <input asp-for="Email" class="form-control text-left" placeholder="example@domain.com" autocomplete="off" />
                                </div>
                                <!-- عرض خطأ هذا الحقل تحديداً -->
                                <span asp-validation-for="Email" class="text-danger d-block mt-1"></span>
                            </div>

                            <!-- كلمة المرور -->
                            <div class="form-group mb-4">
                                <label asp-for="Password" class="control-label fw-bold mb-2">كلمة المرور:</label>
                                <div class="input-group input-group-lg shadow-sm" dir="ltr">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-white"><i class="fas fa-lock text-success"></i></span>
                                    </div>
                                    <input asp-for="Password" class="form-control text-left" placeholder="••••••••" autocomplete="new-password" />
                                </div>
                                <!-- عرض خطأ هذا الحقل تحديداً -->
                                <span asp-validation-for="Password" class="text-danger d-block mt-1"></span>
                            </div>

                            <!-- تأكيد كلمة المرور -->
                            <div class="form-group mb-4">
                                <label asp-for="ConfirmPassword" class="control-label fw-bold mb-2">تأكيد كلمة المرور:</label>
                                <div class="input-group input-group-lg shadow-sm" dir="ltr">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text bg-white"><i class="fas fa-lock text-success"></i></span>
                                    </div>
                                    <input asp-for="ConfirmPassword" class="form-control text-left" placeholder="••••••••" autocomplete="new-password" />
                                </div>
                                <!-- عرض خطأ هذا الحقل تحديداً -->
                                <span asp-validation-for="ConfirmPassword" class="text-danger d-block mt-1"></span>
                            </div>

                        </div>

                        <!-- الأزرار -->
                        <div class="card-footer bg-white pb-4 pt-0 text-center" style="border-radius: 0 0 15px 15px; border-top: none;">
                            <div class="row px-3">
                                <!-- زر التسجيل -->
                                <div class="col-sm-6 mb-2 mb-sm-0">
                                    <button type="submit" class="btn btn-success btn-lg shadow w-100" style="border-radius: 30px; font-weight: bold;">
                                        <i class="fas fa-save ml-1"></i> تسجيل
                                    </button>
                                </div>
                                <!-- زر العودة للقائمة -->
                                <div class="col-sm-6">
                                    <a asp-controller="Adminstration" asp-action="ListUsers" class="btn btn-secondary btn-lg shadow w-100" style="border-radius: 30px; font-weight: bold;">
                                        <i class="fas fa-arrow-right ml-1"></i> القائمة الرئيسية
                                    </a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

    </div>
</section>
<!-- /.content -->
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}