@model CollegeGradingSys.ViewModels.GeneralInfo.GeneralInfoVM

@{
    ViewData["Title"] = "الإعدادات العامة للنظام";
    ViewData["PageName"] = "الإعدادات العامة";
    ViewData["SubPageName"] = "النظام";
}

<section class="content">
    <div class="container-fluid">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <strong>تم بنجاح!</strong> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                <div asp-validation-summary="All" class="text-danger"></div>
            </div>
        }

        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card card-primary shadow-sm mt-3">
                    <div class="card-header bg-dark text-white">
                        <h3 class="card-title mb-0">
                            <i class="fas fa-cogs me-2"></i> الإعدادات العامة وبيانات الترخيص
                        </h3>
                    </div>

                    <form asp-action="Index" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="Id" />

                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-12 mb-3">
                                    <div class="form-group">
                                        <label asp-for="SystemLicenseKey" class="control-label fw-bold">مفتاح ترخيص النظام (License Key)</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light"><i class="fas fa-key text-success"></i></span>
                                            <input asp-for="SystemLicenseKey" class="form-control text-center text-success fw-bold" dir="ltr" placeholder="مثال: A1B2C-D3E4F-5G6H7" style="font-family: Consolas, monospace; font-size: 1.1rem;" />
                                        </div>
                                        <span asp-validation-for="SystemLicenseKey" class="text-danger"></span>
                                        <small class="form-text text-muted">أدخل مفتاح التفعيل هنا لضمان عمل النظام بشكل قانوني على هذا الجهاز.</small>
                                    </div>
                                </div>
                                
                               
                                    <hr class="mt-2 mb-4" />

                                    <div class="col-md-6 mb-3">
                                        <div class="form-group">
                                            <label asp-for="BranchHeadName" class="control-label fw-bold">اسم عميد الكلية / مدير الفرع</label>
                                            <input asp-for="BranchHeadName" class="form-control" placeholder="أدخل اسم العميد" />
                                            <span asp-validation-for="BranchHeadName" class="text-danger"></span>
                                        </div>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <div class="form-group">
                                            <label asp-for="StDepartmentHead" class="control-label fw-bold">رئيس قسم شؤون الطلاب</label>
                                            <input asp-for="StDepartmentHead" class="form-control" placeholder="أدخل اسم رئيس القسم" />
                                            <span asp-validation-for="StDepartmentHead" class="text-danger"></span>
                                        </div>
                                    </div>
                              
                                @*  <div class="col-md-12 mb-3">
                                    <div class="form-group">
                                        <label asp-for="BackupPath" class="control-label fw-bold">مسار حفظ النسخ الاحتياطية (Backup Path)</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light"><i class="fas fa-folder-open text-warning"></i></span>
                                            <input asp-for="BackupPath" class="form-control" dir="ltr" placeholder="D:\Backups\CollegeSystem\" />
                                        </div>
                                        <span asp-validation-for="BackupPath" class="text-danger"></span>
                                        <small class="form-text text-muted">يجب أن يكون هذا المسار موجوداً فعلياً على قرص السيرفر (مثل D أو E).</small>
                                    </div>
                                </div>
 *@
                            </div>
                        </div>

                        <div class="card-footer text-center bg-light">
                            <button type="submit" class="btn btn-primary px-5 fw-bold">
                                <i class="fas fa-save me-1"></i> حفظ التعديلات
                            </button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary px-4">
                                <i class="fas fa-arrow-right me-1"></i> العودة للرئيسية
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}