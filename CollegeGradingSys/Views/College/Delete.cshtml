@model CollegeGradingSys.Models.College

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3>هل تريد بالفعل حذف الكلية</h3>
<div>
   
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            <h6>اسم الكلية</h6>
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CollegeName)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="حذف" class="btn btn-danger" /> |
        <a asp-action="Index">إلغاء الامر</a>
    </form>
</div>
