@using CollegeGradingSys.Models.Enums
@using CollegeGradingSys.ViewModels.Course
@model EditCourseViewModel
<!-- Modal -->
<div class="modal fade " id="add-contact" tabindex="-1" role="dialog" aria-labelledby="addContactLabel" aria-hidden="true">
    <form asp-action="Edit">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <h5 class="modal-title" id="addContactLabel">تعديل المادة </h5>
                </div>

                <hr />
                <div class="modal-body row">

                    <input name="IsValid" type="hidden" value="@ViewData.ModelState.IsValid.ToString()" />

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="Id" />
                    <div class="form-group col-md-6">
                        <label asp-for="SpecializationId" class="control-label"></label>
                        <select asp-for="SpecializationId" class="form-control" asp-items="ViewBag.Specializations"></select>
                    </div>
                    <div class="form-group col-md-6">
                        <label asp-for="Course_sGender" class="control-label"></label>
                        <select asp-for="Course_sGender" class="form-control text-center"
                                asp-items="Html.GetEnumSelectList<Course_sGender>()"></select>
                        <span asp-validation-for="Course_sGender" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-3">
                        <label asp-for="Level" class="control-label"></label>
                        <select asp-for="Level" class="form-control text-center"
                                asp-items="Html.GetEnumSelectList<Level>()"></select>
                        <span asp-validation-for="Level" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-3">
                        <label asp-for="Term" class="control-label"></label>
                        <select asp-for="Term" class="form-control text-center"
                                asp-items="Html.GetEnumSelectList<Term>()"></select>
                        <span asp-validation-for="Term" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-6">
                        <label asp-for="CourseName" class="control-label"></label>
                        <input asp-for="CourseName" class="form-control" />
                        <span asp-validation-for="CourseName" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-6">
                        <label asp-for="BigGrade" class="control-label"></label>
                        <input asp-for="BigGrade" class="form-control" />
                        <span asp-validation-for="BigGrade" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-6">
                        <label asp-for="SmallGrade" class="control-label"></label>
                        <input asp-for="SmallGrade" class="form-control" />
                        <span asp-validation-for="SmallGrade" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-6">

                        <label asp-for="IsSubCourse" class="control-label"></label>
                        <select id="EditCourseIsSubCourse" asp-for="IsSubCourse" class="form-control text-center">
                            <option value="False">مادة أساسية</option>
                            <option value="True">مادة فرعية</option>
                        </select>
                    </div>

                    <div class="form-group col-md-6">
                        <label asp-for="ParentId" class="control-label"></label>
                        <select id="EditCourseParentId" asp-for="ParentId" class="form-control text-center"
                                asp-items="ViewBag.ParentsCourses">
                            @*<option value="-1">-- اختر --</option>*@
                        </select>
                        <span asp-validation-for="ParentId" class="text-danger"></span>
                    </div>
                    <div class="form-group col-md-12">
                        <label asp-for="Note" class="control-label"></label>
                        <input asp-for="Note" class="form-control" />
                        <span asp-validation-for="Note" class="text-danger"></span>
                    </div>
                </div>
                <div class="modal-footer justify-content-between">
                    <button type="button" data-save="modal" class="btn btn-success">حفظ</button>
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">إلغاء الأمر</button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}